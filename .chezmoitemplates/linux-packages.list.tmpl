{{- /* [Rationale]: Strict defensive check for nested osRelease key to prevent 'missingkey=error' on Darwin. */ -}}
{{- $os_id := "" -}}
{{- if (hasKey .chezmoi "osRelease") -}}
  {{- if (hasKey .chezmoi.osRelease "id") -}}
    {{- $os_id = .chezmoi.osRelease.id -}}
  {{- end -}}
{{- end -}}

# [Architecture]: Declarative package list for Linux workstation (2026).
# [Rationale]: This list is distribution-agnostic. Package names are resolved
# where possible, but may require template logic for significant deviations.

# Core Infrastructure
ca-certificates
git
zsh

# Build & Runtime Essentials (Required for Mise toolchain builds)
{{- if or (eq $os_id "ubuntu") (eq $os_id "debian") }}
build-essential
libssl-dev
{{- else if or (eq $os_id "fedora") (eq $os_id "rhel") }}
gcc-c++
openssl-devel
{{- else if eq $os_id "arch" }}
base-devel
openssl
{{- end }}

# Identity & Security Bridge
socat
