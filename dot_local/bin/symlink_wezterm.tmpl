{{- /* Resolve the WezTerm executable path across macOS and WSL boundaries. */ -}}
{{- /* [Reference]: https://www.chezmoi.io/reference/templates/functions/output/ */ -}}
{{- $osid := "linux" -}}
{{- if hasKey . "osid" }}{{ $osid = .osid }}{{ end -}}
{{- $is_wsl := false -}}
{{- if hasKey . "is_wsl" }}{{ $is_wsl = .is_wsl }}{{ end -}}
{{- if eq $osid "darwin" -}}
/Applications/WezTerm.app/Contents/MacOS/wezterm
{{- else if $is_wsl -}}
{{- $win_path := "C:\\Program Files\\WezTerm\\wezterm.exe" -}}
{{- $wsl_path := output "wslpath" "-u" $win_path | trim -}}
{{- if stat $wsl_path -}}
{{- $wsl_path -}}
{{- else -}}
{{- fail "[FATAL] WezTerm.exe not found on Windows host." -}}
{{- end -}}
{{- end -}}
