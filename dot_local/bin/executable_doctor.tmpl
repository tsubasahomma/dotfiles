#!/usr/bin/env zsh
# [Rationale]: Extracted Doctor logic. Standalone binary managed by chezmoi.
# [2026 Best Practice]: CI-aware self-diagnosis to prevent false positives in headless environments.

set -eo pipefail

GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

function log_ok() { echo -e "  ${GREEN}✅ $1${NC}"; }
function log_warn() { echo -e "  ${YELLOW}⚠️  $1${NC}"; }
function log_err() { echo -e "  ${RED}❌ $1${NC}"; return 1; }

# [Rationale]: Detect CI context to adapt validation strictness.
typeset IS_CI="${CI:-false}"

echo "--- 1. Infrastructure Security & Permissions ---"
for dir in "{{ .paths.home }}/.ssh" "{{ .paths.xdg_state }}/ssh"; do
  if [[ -d "$dir" ]]; then
    chmod 700 "$dir"
    log_ok "Hardened permissions for $dir (700)"
  fi
done

echo "--- 2. Identity & Auth Bridge (End-to-End) ---"
if ! ssh-add -l &>/dev/null; then
  if [[ "$IS_CI" == "true" ]]; then
    log_warn "SSH Agent unresponsive (Expected in Headless CI). Skipping deep auth check."
  else
    log_warn "SSH Agent unresponsive. Attempting repair..."
    rm -f "{{ .ssh_auth_sock }}"

    {{ if .is_wsl -}}
    systemctl --user restart 1password-bridge.service || true
    sleep 1
    {{- end }}

    if ! ssh-add -l &>/dev/null; then
      log_err "SSH Agent recovery failed. Check 1Password Developer settings."
    else
      log_ok "SSH Agent bridge recovered successfully."
    fi
  fi
else
  log_ok "SSH Agent is responsive and keys are loaded."
fi

echo "--- 3. Runtime Integrity (Neovim Provider) ---"
NVIM_PYTHON="{{ .paths.xdg_data }}/nvim/venv/bin/python"
if [[ -x "$NVIM_PYTHON" ]]; then
  if "$NVIM_PYTHON" -c "import pynvim" &>/dev/null; then
    log_ok "Neovim Python provider is healthy."
  else
    log_warn "pynvim missing in venv. Re-provisioning..."
    uv pip install --python "$NVIM_PYTHON" pynvim &>/dev/null
    log_ok "pynvim re-installed."
  fi
else
  log_err "Neovim venv missing at $NVIM_PYTHON"
fi

echo "--- 4. Network & Known Hosts (Validation) ---"
# [Rationale]: Doctor must only READ state. Mutation (ssh-keyscan) is explicitly shifted to Phase 00 provisioning.
if ! ssh-keygen -F github.com -f "{{ .paths.xdg_state }}/ssh/known_hosts" &>/dev/null; then
  log_err "GitHub not in known_hosts. Initial provisioning phase (00-validate-session) may have failed."
else
  log_ok "GitHub host key verified."
fi

echo -e "\n${GREEN}✨ System Health: Optimal${NC}"
