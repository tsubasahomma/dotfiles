#!/bin/sh
{{/* [Reference]: https://www.chezmoi.io/user-guide/templating/ */ -}}
# [Rationale]: Self-healing diagnostic engine with actionable guidance.
# [Architecture]: POSIX-compliant (sh) OS-agnostic checks with schema-safe evaluation.

set -u

GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

log_ok() { printf "  ${GREEN}✅ %s${NC}\n" "$1"; }
log_warn() { printf "  ${YELLOW}⚠️  %s${NC}\n" "$1"; }
log_err() { printf "  ${RED}❌ %s${NC}\n" "$1"; return 1; }
log_guide() { printf "  ${BLUE}👉 %s${NC}\n" "$1"; }

IS_CI="${CI:-false}"
HOME_DIR="{{ .chezmoi.homeDir }}"
OP_BIN="{{ .paths.op }}"

echo "--- 1. Infrastructure Security & Permissions ---"
for dir in "$HOME_DIR/.ssh" "{{ .paths.xdg_state }}/ssh"; do
  if [ -d "$dir" ]; then
    chmod 700 "$dir"
    log_ok "Hardened permissions for $dir (700)"
  fi
done

echo "--- 2. Identity & Auth Bridge Analysis (Interop) ---"
# [Dynamic Check]: Evaluates the target binary (Linux or Windows via Interop).
if "$OP_BIN" account get > /dev/null 2>&1; then
  GH_USER="{{ .gh_user }}"
  log_ok "Sovereign Identity authenticated: $GH_USER"
else
  log_warn "Sovereign Identity is locked."
  log_guide "Action: Unlock 1Password Desktop App or run '$OP_BIN signin'."
fi

echo "--- 3. SSH Agent & Cryptographic Trust ---"
if ssh-add -l > /dev/null 2>&1; then
  log_ok "SSH Agent is healthy."
else
  if [ "$IS_CI" = "true" ]; then
    log_warn "SSH Agent unresponsive (CI mode). Skipping."
  else
    log_warn "SSH Agent unresponsive. Attempting bridge recovery..."
    {{ if .is_wsl -}}
    if command -v systemctl >/dev/null 2>&1; then
      systemctl --user restart 1password-bridge.service || true
    fi
    {{ end -}}
    sleep 1
    ssh-add -l > /dev/null 2>&1 || {
      log_err "Auth bridge failed."
      log_guide "Verify 1Password [SSH Agent] setting is enabled and the app is unlocked."
    }
  fi
fi

echo "--- 4. Neovim Deterministic State ---"
LOCK_FILE="{{ .paths.xdg_config }}/nvim/lazy-lock.json"
if [ -f "$LOCK_FILE" ]; then
  chezmoi verify "$LOCK_FILE" > /dev/null 2>&1 && log_ok "lazy-lock.json is synchronized." || log_warn "lazy-lock.json drift detected."
else
  log_err "lazy-lock.json is missing."
fi

NVIM_PYTHON="{{ .paths.xdg_data }}/nvim/venv/bin/python"
[ -x "$NVIM_PYTHON" ] && log_ok "Hermetic Python Provider ready ($NVIM_PYTHON)" || log_err "Python Provider missing"

echo "--- 5. Vale & Prose Linting Integrity ---"
STYLE_DIR="{{ .paths.xdg_data }}/vale/styles/Google"
if [ -d "$STYLE_DIR" ]; then
  log_ok "Vale & Google Style provisioned."
else
  log_err "Styles missing at $STYLE_DIR"
  log_guide "Action: Run 'chezmoi apply' to trigger self-healing sync."
fi

echo "--- 6. Toolchain Drift Analysis ---"
MISE_BIN="{{ .paths.mise }}"
[ -x "$MISE_BIN" ] && log_ok "Hermetic mise binary verified." || log_err "mise missing."

if echo "$PATH" | grep -q "^$HOME_DIR/.local/bin"; then
  log_ok "PATH precedence correctly prioritizes .local/bin"
else
  log_warn "PATH precedence violation detected."
fi

printf "\n${GREEN}✨ System Health Evaluation Complete${NC}\n"
