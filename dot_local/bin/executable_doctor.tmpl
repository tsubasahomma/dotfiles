#!/usr/bin/env zsh
# [Rationale]: Self-healing diagnostic engine.
# [Architecture]: OS-agnostic checks with WSL2-specific bridge validation.

set -eo pipefail

GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

function log_ok() { echo -e "  ${GREEN}✅ $1${NC}"; }
function log_warn() { echo -e "  ${YELLOW}⚠️  $1${NC}"; }
function log_err() { echo -e "  ${RED}❌ $1${NC}"; return 1; }

typeset IS_CI="${CI:-false}"

echo "--- 1. Infrastructure Security & Permissions ---"
for dir in "{{ .paths.home }}/.ssh" "{{ .paths.xdg_state }}/ssh"; do
  if [[ -d "$dir" ]]; then
    chmod 700 "$dir"
    log_ok "Hardened permissions for $dir (700)"
  fi
done

echo "--- 2. Identity & Auth Bridge ---"
if ! ssh-add -l &>/dev/null; then
  if [[ "$IS_CI" == "true" ]]; then
    log_warn "SSH Agent unresponsive (CI mode). Skipping."
  else
    log_warn "SSH Agent unresponsive. Attempting bridge recovery..."

    {{ if .is_wsl -}}
    # [WSL2 Specific]: Verify systemd user service status for npiperelay bridge.
    if ! systemctl --user is-active 1password-bridge.service &>/dev/null; then
      log_warn "1password-bridge.service is inactive. Restarting..."
      systemctl --user restart 1password-bridge.service || true
    fi
    {{- end }}

    sleep 1
    if ! ssh-add -l &>/dev/null; then
      log_err "Auth bridge failed. Please verify 1Password 'SSH Agent' settings."
    else
      log_ok "SSH Agent bridge verified."
    fi
  fi
else
  log_ok "SSH Agent is healthy."
fi

echo "--- 3. Runtime & Identity Sync ---"
if [[ "{{ .gh_user }}" == "pending" ]]; then
  log_err "Identity Pointer resolution failed. (gh_user: pending)"
else
  log_ok "Sovereign Identity resolved: {{ .gh_user }}"
fi

echo -e "\n${GREEN}✨ System Health: Optimal${NC}"
