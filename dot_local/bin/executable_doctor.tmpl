#!/bin/sh
# [Rationale]: Self-healing diagnostic engine.
# [Architecture]: POSIX-compliant (sh) OS-agnostic checks.
# [Reference]: https://pubs.opengroup.org/onlinepubs/9699919799/utilities/sh.html

set -u

GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

log_ok() { printf "  ${GREEN}✅ %s${NC}\n" "$1"; }
log_warn() { printf "  ${YELLOW}⚠️  %s${NC}\n" "$1"; }
log_err() { printf "  ${RED}❌ %s${NC}\n" "$1"; return 1; }

IS_CI="${CI:-false}"

echo "--- 1. Infrastructure Security & Permissions ---"
for dir in "{{ .paths.home }}/.ssh" "{{ .paths.xdg_state }}/ssh"; do
  if [ -d "$dir" ]; then
    chmod 700 "$dir"
    log_ok "Hardened permissions for $dir (700)"
  fi
done

echo "--- 2. Identity & Auth Bridge ---"
if ! ssh-add -l > /dev/null 2>&1; then
  if [ "$IS_CI" = "true" ]; then
    log_warn "SSH Agent unresponsive (CI mode). Skipping."
  else
    log_warn "SSH Agent unresponsive. Attempting bridge recovery..."

    {{ if .is_wsl -}}
    if command -v systemctl >/dev/null 2>&1; then
      if ! systemctl --user is-active 1password-bridge.service > /dev/null 2>&1; then
        log_warn "1password-bridge.service is inactive. Restarting..."
        systemctl --user restart 1password-bridge.service || true
      fi
    fi
    {{- end }}

    sleep 1
    if ! ssh-add -l > /dev/null 2>&1; then
      log_err "Auth bridge failed. Please verify 1Password 'SSH Agent' settings."
    else
      log_ok "SSH Agent bridge verified."
    fi
  fi
else
  log_ok "SSH Agent is healthy."
fi

echo "--- 3. Runtime & Identity Sync ---"
{{ if eq .gh_user "wsl-bootstrap" -}}
log_warn "Identity Pointer is in Bootstrap mode (op.exe not found)."
echo "  👉 Action: Install 1Password CLI on Windows or wait for provisioning, then run 'chezmoi init'."
{{- else -}}
log_ok "Sovereign Identity resolved: {{ .gh_user }}"
{{- end }}

echo "--- 4. Neovim Deterministic State ---"
LOCK_FILE="{{ .paths.xdg_config }}/nvim/lazy-lock.json"
if [ -f "$LOCK_FILE" ]; then
  if chezmoi managed "$LOCK_FILE" > /dev/null 2>&1; then
    if chezmoi verify "$LOCK_FILE" > /dev/null 2>&1; then
      log_ok "lazy-lock.json is synchronized with Foundation Schema."
    else
      log_warn "lazy-lock.json has uncommitted local changes. Run 'chezmoi add $LOCK_FILE'."
    fi
  else
    log_warn "lazy-lock.json is not managed by chezmoi. Run 'chezmoi add $LOCK_FILE'."
  fi
else
  log_err "lazy-lock.json is missing."
fi

NVIM_PYTHON="{{ .paths.xdg_data }}/nvim/venv/bin/python"
if [ -x "$NVIM_PYTHON" ]; then
  if "$NVIM_PYTHON" -c "import pynvim" > /dev/null 2>&1; then
    log_ok "Hermetic Python Provider is ready ($NVIM_PYTHON)"
  else
    log_err "pynvim module is missing in the Hermetic Provider."
  fi
else
  log_err "Hermetic Python Provider not found at $NVIM_PYTHON"
fi

echo "--- 5. Toolchain Drift Analysis (Self-Healing Engine) ---"
MISE_BIN="{{ .paths.home }}/.local/bin/mise"
if [ -x "$MISE_BIN" ]; then
  log_ok "Hermetic mise binary verified at $MISE_BIN"
else
  log_err "mise binary is missing or not executable. System integrity compromised."
fi

if echo "$PATH" | grep -q "^{{ .paths.home }}/.local/bin"; then
  log_ok "PATH precedence correctly prioritizes .local/bin"
else
  log_warn "PATH precedence violation. .local/bin is not at the front of PATH."
fi

printf "\n${GREEN}✨ System Health: Optimal${NC}\n"
