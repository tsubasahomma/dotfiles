{{ if eq .osid "darwin" -}}
#!/bin/zsh
# [chezmoi-script]: Tier 1 (Zsh)
# [Architecture]: macOS Provisioning Engine.
# [Rationale]: Managed via Brew Bundle.
# dot_config/homebrew/Brewfile.tmpl hash: {{ include "dot_config/homebrew/Brewfile.tmpl" | sha256sum }}

set -euo pipefail

# [Architecture]: Localized Binary Resolution (Commodity)
# [Rationale]: 100% reliant on 'lookPath' without hardcoded fallbacks to eliminate Path Precedence Hallucinations.
CURL_BIN="{{ lookPath "curl" }}"
BASH_BIN="{{ lookPath "bash" }}"

if [ -z "$CURL_BIN" ] || [ -z "$BASH_BIN" ]; then
  echo "❌ [Fatal] Essential commodity binaries (curl, bash) not found in PATH."
  exit 1
fi

# [Architecture]: Package Manager Abstraction for Darwin.
install_packages() {
  if [ -f "$1" ]; then
    echo "📦 [Infrastructure] Installing Brewfile bundle: $1"
    export HOMEBREW_BUNDLE_NO_LOCK=1
    brew bundle install --file="$1"
  else
    echo "📦 [Infrastructure] Installing brew packages: $*"
    brew install "$@"
  fi
}

if ! command -v brew &> /dev/null; then
  echo "📦 [Infrastructure] Installing Homebrew..."
  # [Rationale]: Execute brew installer with dynamic bash/curl.
  "$BASH_BIN" -c "$("$CURL_BIN" -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi

if [[ -x "/opt/homebrew/bin/brew" ]]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
elif [[ -x "/usr/local/bin/brew" ]]; then
  eval "$(/usr/local/bin/brew shellenv)"
fi

brew update
TEMP_BREWFILE=$(mktemp)
cat << 'EOF' > "$TEMP_BREWFILE"
{{ includeTemplate "dot_config/homebrew/Brewfile.tmpl" . }}
EOF

install_packages "$TEMP_BREWFILE"
rm "$TEMP_BREWFILE"

{{ else if eq .osid "linux" -}}
#!/bin/sh
# [chezmoi-script]: L0 (POSIX Shell) Tiering
# [Architecture]: OS-Agnostic Linux Provisioning Engine.
# [Rationale]: Dynamic PM discovery and package abstraction.
# [Trigger]: Linux package list hash: {{ includeTemplate "linux-packages.list.tmpl" . | sha256sum }}

set -eu

# --- 1. Infrastructure Discovery ---

OS_RELEASE_PATH=""
if [ -r "/etc/os-release" ]; then
  OS_RELEASE_PATH="/etc/os-release"
elif [ -r "/usr/lib/os-release" ]; then
  OS_RELEASE_PATH="/usr/lib/os-release"
fi

if [ -z "$OS_RELEASE_PATH" ]; then
  echo "❌ [Fatal] OS identification file missing."
  exit 1
fi

. "$OS_RELEASE_PATH"

# [Architecture]: Positive Package Manager Detection.
case "$ID" in
  ubuntu|debian) PM="apt" ;;
  fedora|rhel)   PM="dnf" ;;
  arch)          PM="pacman" ;;
  *)
    echo "❌ [Fatal] Unsupported distribution: $ID"
    exit 1
    ;;
esac

# --- 2. Package Manager Abstraction ---

install_packages() {
  packages="$*"
  echo "📦 [Infrastructure] Installing packages via $PM: $packages"

  case "$PM" in
    apt)
      sudo apt-get update -y
      sudo apt-get install -y $packages
      ;;
    dnf)
      sudo dnf install -y $packages
      ;;
    pacman)
      sudo pacman -S --noconfirm $packages
      ;;
  esac
}

# --- 3. Execution ---

TEMP_PKG_LIST=$(mktemp)
cat << 'EOF' > "$TEMP_PKG_LIST"
{{ includeTemplate "linux-packages.list.tmpl" . }}
EOF

TARGET_PKGS=$(grep -vE '^\s*(#|$)' "$TEMP_PKG_LIST" | xargs)
if [ -n "$TARGET_PKGS" ]; then
  install_packages "$TARGET_PKGS"
fi
rm -f "$TEMP_PKG_LIST"

# --- 4. Deterministic Shell Management ---
ZSH_PATH=$(command -v zsh || true)

if [ -z "$ZSH_PATH" ]; then
  echo "❌ [Error] Zsh was not found after installation phase."
  exit 1
fi

if ! grep -q "$ZSH_PATH" /etc/shells; then
  echo "🔐 [Infrastructure] Registering $ZSH_PATH in /etc/shells..."
  echo "$ZSH_PATH" | sudo tee -a /etc/shells
fi

CURRENT_USER_SHELL=$(getent passwd "$USER" | cut -d: -f7)
if [ "$CURRENT_USER_SHELL" != "$ZSH_PATH" ]; then
  echo "🔄 [Infrastructure] Transitioning default shell to $ZSH_PATH..."
  sudo chsh -s "$ZSH_PATH" "$USER"
else
  echo "✅ [Infrastructure] Default shell is already deterministic ($ZSH_PATH)."
fi

echo "✨ [Infrastructure] Linux base provisioning complete ($ID)."
{{ end -}}
