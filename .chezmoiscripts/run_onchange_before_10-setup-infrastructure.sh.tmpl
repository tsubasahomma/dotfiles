{{ if eq .osid "darwin" -}}
#!/bin/zsh
# [chezmoi-script]: Tier 1 (Zsh)
# [Rationale]: Managed via Brew Bundle.
# dot_config/homebrew/Brewfile.tmpl hash: {{ include "dot_config/homebrew/Brewfile.tmpl" | sha256sum }}

set -euo pipefail

CURL_BIN="/usr/bin/curl"
BASH_BIN="/bin/bash"

if ! command -v brew &> /dev/null; then
  echo "📦 [Infrastructure] Installing Homebrew..."
  "$BASH_BIN" -c "$("$CURL_BIN" -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi

if [[ -x "/opt/homebrew/bin/brew" ]]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
elif [[ -x "/usr/local/bin/brew" ]]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
fi

brew update
TEMP_BREWFILE=$(mktemp)
cat << 'EOF' > "$TEMP_BREWFILE"
{{ includeTemplate "dot_config/homebrew/Brewfile.tmpl" . }}
EOF

export HOMEBREW_BUNDLE_NO_LOCK=1
brew bundle install --file="$TEMP_BREWFILE"
rm "$TEMP_BREWFILE"

{{ else if eq .osid "linux" -}}
#!/bin/bash
# [chezmoi-script]: L0 (POSIX Shell/Bash fallback)
# [Rationale]: Uses Bash to guarantee execution before Zsh is present in the system shells.
# [Trigger]: Linux package list hash: {{ include "dot_config/apt/packages.list.tmpl" | sha256sum }}

set -euo pipefail

echo "📦 [Infrastructure] Provisioning Linux Base Dependencies via APT..."

# [Rationale]: Ensure package lists are fresh before installation.
sudo apt-get update -y

# [Architecture]: Loop-based installation from externalized package list.
# Renders the template into a temporary list to avoid physical file dependencies.
TEMP_PKG_LIST=$(mktemp)
cat << 'EOF' > "$TEMP_PKG_LIST"
{{ include "dot_config/apt/packages.list.tmpl" }}
EOF

# [Rationale]: Filter comments and empty lines, then batch install.
# --no-run-if-empty prevents execution failure if the list is completely empty.
grep -vE '^\s*(#|$)' "$TEMP_PKG_LIST" | xargs --no-run-if-empty sudo apt-get install -y
rm "$TEMP_PKG_LIST"

# [Rationale]: Defensive registration of Zsh path.
if ! grep -q "/usr/bin/zsh" /etc/shells; then
  echo "/usr/bin/zsh" | sudo tee -a /etc/shells
fi

# [Architecture]: Deterministic Shell Enforcement
# [Rationale]: Ensure the default login shell matches the dotfiles' primary runtime.
# Evaluated defensively to maintain absolute idempotency.
CURRENT_SHELL=$(grep "^$USER:" /etc/passwd | cut -d: -f7)
if [ "$CURRENT_SHELL" != "/usr/bin/zsh" ]; then
  echo "🔄 [Infrastructure] Changing default shell to /usr/bin/zsh..."
  sudo chsh -s /usr/bin/zsh "$USER"
fi

echo "✅ [Infrastructure] Linux base provisioning complete."
{{ end -}}
