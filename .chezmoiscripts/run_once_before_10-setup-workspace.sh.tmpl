#!/bin/zsh
# [chezmoi-script]: Source: '.chezmoiscripts/run_...' vs Dry-run: '.chezmoiscripts/...'
# [Rationale]: Guarantee the existence of all dynamically routed workspaces.

set -euo pipefail

echo "📁 [Workspace] Provisioning dynamically routed workspace directories..."

{{ $home := .paths.home -}}
{{ range .identities -}}
{{   $name := .name -}}
{{   $dirs := splitList "," .dirs -}}
{{   range $dirs -}}
{{     $normalized_dir := trim . -}}
{{     if hasPrefix "~/" $normalized_dir -}}
{{       $normalized_dir = joinPath $home (trimPrefix "~/" $normalized_dir) -}}
{{     end -}}
# [Policy]: Target mapping for {{ $name }}
RAW_DIR="{{ $normalized_dir }}"

# [Architecture]: Strip wildcard suffixes (e.g., /Jitera*) to safely resolve the base directory
BASE_DIR="${RAW_DIR%%\**}"

if [[ ! -d "$BASE_DIR" ]]; then
  echo "  📦 mkdir: $BASE_DIR"
  mkdir -p "$BASE_DIR"
fi
{{   end -}}
{{ end -}}
