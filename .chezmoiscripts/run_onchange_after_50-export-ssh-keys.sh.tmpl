#!/bin/zsh
# =============================================================================
# [Architecture]: Atomic Identity Pipeline | Phase 50 (Multi-Account O(1) Batch)
# [Rationale]: Resolves secrets across ALL signed-in 1Password accounts.
#              Complexity: O(2A) where A is the number of accounts.
# [Reference]: https://developer.1password.com/docs/cli/reference/commands/inject
# [Trigger]: 1Password Key Rotation Hash: {{ .ssh_keys_hash }}
# =============================================================================

set -euo pipefail

# --- 1. CI / Bootstrapping Guards ---
if [[ "${CI:-false}" == "true" ]]; then
  echo "⚠️  [Identity] CI environment detected. Skipping SSH key export."
  exit 0
fi

if [[ "{{ .op_status }}" == "missing" ]]; then
  echo "⚠️  [Identity] Bootstrapping Mode: Skipping SSH key export until op.exe is provisioned."
  exit 0
fi

# --- 2. Toolchain Resolution ---
OP_BIN="{{ .paths.op }}"
JQ_BIN=$(command -v jq || true)

if [[ ! -x "$OP_BIN" ]] && ! command -v "$OP_BIN" &>/dev/null; then
  echo "❌ [Fatal] Required binaries not found or not executable. (op: $OP_BIN, jq: $JQ_BIN)"
  exit 1
fi

if [[ -z "$JQ_BIN" ]] || [[ ! -x "$JQ_BIN" ]]; then
  echo "❌ [Fatal] jq binary not found or not executable."
  exit 1
fi

TARGET_DIR="{{ .paths.home }}/.ssh"
mkdir -p "$TARGET_DIR"
chmod 700 "$TARGET_DIR"

echo "🔐 [Identity] Provisioning identity resources via Multi-Account Batch Pipeline..."

# --- 3. Multi-Account Discovery ---
ACCOUNTS=$("$OP_BIN" account list --format json | "$JQ_BIN" -r '.[].url')

if [[ -z "$ACCOUNTS" ]]; then
  echo "⚠️  [Identity] No signed-in 1Password accounts found."
  exit 0
fi

# --- 4. Iterative Batch Processing ---
while read -r account_url; do
  echo "🔍 [Account] Scanning: $account_url"

  items_json=$("$OP_BIN" item list --tags dotfiles-ssh-key --account "$account_url" --format json 2>/dev/null || echo "[]")

  item_count=$(echo "$items_json" | "$JQ_BIN" 'length')
  if [[ "$item_count" -eq 0 ]]; then
    echo "  ⏭️  No matching SSH keys in this account."
    continue
  fi

  echo "  📦 Found $item_count items. Resolving via Batch Inject..."

  # [Architecture]: Removed dotfiles_link_id. The item itself is the target key.
  TEMPLATE=$("$JQ_BIN" -r '.[] | "\(.id)\t\(.vault.id)\t{{ "{{" }}op://\(.vault.id)/\(.id)/key type{{ "}}" }}\t{{ "{{" }}op://\(.vault.id)/\(.id)/public key{{ "}}" }}"' <<< "$items_json")

  if ! RESOLVED_TSV=$(echo "$TEMPLATE" | "$OP_BIN" inject --account "$account_url" 2>/dev/null); then
    echo "  ❌ [Error] Failed to batch-resolve secrets for $account_url."
    continue
  fi

  # Atomic File Export
  echo "$RESOLVED_TSV" | while IFS=$'\t' read -r item_id vault_id k_type pubkey; do
    item_id="${item_id%$'\r'}"
    vault_id="${vault_id%$'\r'}"
    k_type="${k_type%$'\r'}"
    pubkey="${pubkey%$'\r'}"

    if [[ -z "$item_id" ]] || [[ -z "$pubkey" ]]; then
      continue
    fi

    PUBKEY_FILE="$TARGET_DIR/id_${k_type}_${vault_id}_${item_id}.pub"
    echo "  ✅ [Export] Syncing: $item_id ($k_type)"
    echo "$pubkey" > "$PUBKEY_FILE"
    chmod 600 "$PUBKEY_FILE"
  done

done <<< "$ACCOUNTS"

echo "✅ [Identity] All identities across all accounts have been synchronized."
