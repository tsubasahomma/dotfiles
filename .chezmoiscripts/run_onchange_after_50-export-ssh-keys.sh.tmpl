#!/bin/zsh
# [Architecture]: Resource Export Engine | VADKD v5.1 Protocol.
# [Rationale]: Replaced 'echo' with 'printf' to prevent Zsh from mangling JSON escaping.

set -euo pipefail

if [[ "${CI:-}" == "true" ]]; then exit 0; fi

OP_BIN="{{ .paths.op }}"
JQ_BIN="{{ .paths.jq }}"
{{ if .is_wsl }}OP_BIN="op.exe"{{ end }}

umask 077
TARGET_DIR="{{ .paths.home }}/.ssh"
mkdir -p "$TARGET_DIR"

typeset -A resolved_keys

echo "🔍 [Discovery] Scanning 1Password for Identity Resources via VADKD v5.1 Protocol..."

typeset accounts
if ! accounts=$("$OP_BIN" account list --format json | "$JQ_BIN" -r '.[].url'); then exit 0; fi

for url in ${(f)accounts}; do
  typeset items
  if ! items=$("$OP_BIN" item list --tags "dotfiles-ssh-key" --account "$url" --format json 2> /dev/null); then continue; fi

  # [Rationale]: printf %s preserves raw JSON structure including escaped backslashes.
  printf '%s\n' "$items" | "$JQ_BIN" -c '.[]' | while read -r item; do
    id=$(printf '%s\n' "$item" | "$JQ_BIN" -r '.id')
    v_id=$(printf '%s\n' "$item" | "$JQ_BIN" -r '.vault.id')

    if [[ -z "$id" ]]; then continue; fi

    fields=$("$OP_BIN" item get "$id" --account "$url" --format json | "$JQ_BIN" -c '.fields[]?')

    link_id=$(printf '%s\n' "$fields" | "$JQ_BIN" -r 'select(.label=="dotfiles_link_id") | .value // empty')
    k_type=$(printf '%s\n' "$fields" | "$JQ_BIN" -r 'select(.label=="key type") | .value // empty')

    if [[ -n "$link_id" ]]; then
      if [[ ! "$link_id" =~ ^[a-zA-Z0-9_-]+$ ]]; then continue; fi
      if [[ -z "$k_type" ]]; then k_type="ed25519"; fi

      filename="id_${k_type}_${v_id}_${link_id}.pub"
      target_path="$TARGET_DIR/$filename"

      if [[ -n "${resolved_keys[$filename]:-}" ]]; then
        echo "❌ [Error] Duplicate resource collision for '$filename'. Aborting."
        exit 1
      fi

      if pubkey=$("$OP_BIN" item get "$id" --account "$url" --fields label="public key" 2> /dev/null); then
        echo "$pubkey" > "$target_path"
        echo "✅ [Export] Discovered Resource '$link_id' ($k_type) -> Wrote to $filename"
        resolved_keys[$filename]="resolved"
      fi
    fi
  done
done
