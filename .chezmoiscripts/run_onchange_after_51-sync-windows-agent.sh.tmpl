#!/bin/zsh
# Phase 51 syncs the rendered 1Password agent config to the Windows host.
# [Trigger]: 1Password agent config hash: {{ includeTemplate "dot_config/1Password/ssh/private_agent.toml.tmpl" . | sha256sum }}

set -euo pipefail

{{ if .is_wsl -}}
WIN_HOME=$(powershell.exe -NoProfile -NonInteractive -Command '[Console]::Write($env:USERPROFILE)' | tr -d '\r')
DST_CONFIG_WIN="$(wslpath -u "$WIN_HOME")/AppData/Local/1Password/config/ssh/agent.toml"

SRC_CONFIG="{{ .paths.xdg_config }}/1Password/ssh/agent.toml"
if [[ -f "$SRC_CONFIG" ]]; then
  echo "🌉 [Infrastructure] Syncing 1Password Agent to Windows..."
  mkdir -p "$(dirname "$DST_CONFIG_WIN")"
  cp -f "$SRC_CONFIG" "$DST_CONFIG_WIN"
fi
{{- end }}
