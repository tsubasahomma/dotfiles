#!/bin/sh
{{ "" -}}
# [Architecture]: Sovereign Session Validation
# [Rationale]: Prevents cascading failures by asserting 1Password availability.
# [Reference]: https://developer.1password.com/docs/cli/reference/commands/account

set -eu
{{- if eq .op_status "missing" }}
echo "⚠️  [Identity] 1Password CLI not detected. Basic provisioning will proceed without identities." >&2
exit 0
{{- else if eq .op_status "locked" }}
if [ "${CI:-false}" = "true" ]; then
  exit 0
fi

echo "❌ [Identity] 1Password session is locked." >&2
echo "👉 Action Required: Run 'op signin' and then 'chezmoi apply'." >&2
exit 1
{{- end }}

exit 0
