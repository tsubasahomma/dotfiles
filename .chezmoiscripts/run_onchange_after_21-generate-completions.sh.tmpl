#!/bin/zsh
# [Architecture]: Compile-time Completion & Init Engine (Performance Hardened)
# [Rationale]: Generates static scripts and pre-compiles them into byte-code (.zwc)
# to minimize I/O and parse time during shell startup. Includes Orphan-Purge logic.
# [Reference: Zsh Performance]: https://htr3n.github.io/2018/07/faster-zsh/
# [Reference: Chezmoi Completion]: https://www.chezmoi.io/reference/commands/completion/
# [Trigger]: Config: {{ include "dot_config/mise/config.toml.tmpl" | sha256sum }}
# [Trigger]: Mise Binary: {{ index .tool_integrity.mise.hashes (printf "%s-%s" .osid .arch) }}
# [Trigger]: Chezmoi Version: {{ .tool_integrity.chezmoi.version }}

set -euo pipefail

MISE_BIN="{{ .paths.mise }}"
CACHE_DIR="{{ .paths.xdg_cache }}/zsh"
COMP_DIR="$CACHE_DIR/completions"
INIT_DIR="$CACHE_DIR/init"
ZCOMPDUMP="$CACHE_DIR/zcompdump"

echo "⚙️  [Infrastructure] Provisioning static Zsh assets..."

mkdir -p "$COMP_DIR" "$INIT_DIR"

# [Architecture]: Orphaned Byte-code Purge
echo "🧹 [Infrastructure] Purging outdated byte-codes..."
find "$CACHE_DIR" -name "*.zwc" -type f -delete 2>/dev/null || true

# --- Phase 1: Completion Generation ---
# [Rationale]: Generate completions for both external tools and the engine itself.
"$MISE_BIN" exec gh -- gh completion -s zsh > "$COMP_DIR/_gh"
"$MISE_BIN" exec ripgrep -- rg --generate complete-zsh > "$COMP_DIR/_rg"
"$MISE_BIN" exec fd -- fd --gen-completions zsh > "$COMP_DIR/_fd"
"$MISE_BIN" exec uv -- uv generate-shell-completion zsh > "$COMP_DIR/_uv"

# [Self-Completion]: Inject current chezmoi binary completions.
"{{ .chezmoi.executable }}" completion zsh > "$COMP_DIR/_chezmoi"

# --- Phase 2: Static Init Generation & Compilation ---
"$MISE_BIN" activate zsh > "$INIT_DIR/mise.zsh"
"$MISE_BIN" exec zoxide -- zoxide init zsh > "$INIT_DIR/zoxide.zsh"
"$MISE_BIN" exec starship -- starship init zsh --print-full-init > "$INIT_DIR/starship.zsh"

# [Architecture]: Byte-code Compilation
for f in "$INIT_DIR"/*.zsh; do
  zcompile -U "$f"
done

# [Self-Healing Logic]: Cache Invalidation
if [[ -f "$ZCOMPDUMP" ]]; then
  echo "🧹 [Infrastructure] Invalidating Zsh compdump cache..."
  rm -f "$ZCOMPDUMP"
  rm -f "${ZCOMPDUMP}.zwc" 2>/dev/null || true
fi

echo "✅ [Infrastructure] All static assets and byte-codes provisioned."
