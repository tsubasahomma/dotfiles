#!/bin/zsh
{{ "" -}}
# [Architecture]: Compile-time Completion & Init Engine (Deterministic Phase)
# [Trigger]: Ecosystem Schema: {{ include ".chezmoidata/tools.yaml" | sha256sum }}

set -euo pipefail
setopt extended_glob

{{- $id_gh := "gh" -}}
{{- $id_ripgrep := "ripgrep" -}}
{{- $id_fd := "fd" -}}
{{- $id_uv := "uv" -}}
{{- $id_starship := "starship" -}}
{{- $id_yq := "yq" -}}
{{- $id_doggo := "doggo" -}}
{{- $id_kubectl := "kubectl" -}}
{{- $id_helm := "helm" -}}
{{- $id_k9s := "k9s" -}}
{{- $id_delta := "delta" -}}
{{- $id_hs := "npm:@hubspot/cli" -}}
{{- $id_pnpm := "pnpm" -}}

{{- /* [Architecture]: Dynamic Tool Identifier Resolution */ -}}
{{- range $k, $v := .mise_tools -}}
  {{- if eq $k "gh" }}{{ $id_gh = $k }}{{ end -}}
  {{- if eq $k "ripgrep" }}{{ $id_ripgrep = $k }}{{ end -}}
  {{- if eq $k "fd" }}{{ $id_fd = $k }}{{ end -}}
  {{- if eq $k "uv" }}{{ $id_uv = $k }}{{ end -}}
  {{- if hasPrefix "starship" $k }}{{ $id_starship = $k }}{{ end -}}
  {{- if contains "/yq" $k }}{{ $id_yq = $k }}{{ end -}}
  {{- if contains "doggo" $k }}{{ $id_doggo = $k }}{{ end -}}
  {{- if contains "kubectl" $k }}{{ $id_kubectl = $k }}{{ end -}}
  {{- if contains "helm" $k }}{{ $id_helm = $k }}{{ end -}}
  {{- if contains "k9s" $k }}{{ $id_k9s = $k }}{{ end -}}
  {{- if contains "delta" $k }}{{ $id_delta = $k }}{{ end -}}
  {{- if contains "@hubspot/cli" $k }}{{ $id_hs = $k }}{{ end -}}
  {{- if eq $k "pnpm" }}{{ $id_pnpm = $k }}{{ end -}}
{{- end }}

MISE_BIN="{{ .paths.mise }}"
COMP_DIR="{{ .paths.xdg_cache }}/zsh/completions"
INIT_DIR="{{ .paths.xdg_cache }}/zsh/init"

echo "⚙️  [Infrastructure] Provisioning static Zsh assets..."
mkdir -p "$COMP_DIR" "$INIT_DIR"

# [Architecture]: Precise Execution Wrapper
# [Rationale]: Separates the exact mise plugin ID ($1) from the binary executable ($2) to strictly conform to `mise exec <id> -- <bin> <args>` syntax.
generate_comp() {
  local mise_id="$1"
  local bin_name="$2"
  shift 2
  echo "  📦 [Completions] Generating for: $bin_name" >&2
  "$MISE_BIN" exec "$mise_id" -- "$bin_name" "$@" || echo "  ⚠️  [Warn] Failed to generate completions for $bin_name. Skipping." >&2
}

# --- Phase 1: Verified Completion Generation ---
"$MISE_BIN" completion zsh > "$COMP_DIR/_mise"

generate_comp "{{ $id_gh }}" "gh" completion -s zsh > "$COMP_DIR/_gh"
generate_comp "{{ $id_ripgrep }}" "rg" --generate complete-zsh > "$COMP_DIR/_rg"
generate_comp "{{ $id_fd }}" "fd" --gen-completions zsh > "$COMP_DIR/_fd"
generate_comp "{{ $id_uv }}" "uv" generate-shell-completion zsh > "$COMP_DIR/_uv"
generate_comp "{{ $id_starship }}" "starship" completions zsh > "$COMP_DIR/_starship"
generate_comp "{{ $id_yq }}" "yq" completion zsh > "$COMP_DIR/_yq"
generate_comp "{{ $id_doggo }}" "doggo" completions zsh > "$COMP_DIR/_doggo"
generate_comp "{{ $id_kubectl }}" "kubectl" completion zsh > "$COMP_DIR/_kubectl"
generate_comp "{{ $id_helm }}" "helm" completion zsh > "$COMP_DIR/_helm"
generate_comp "{{ $id_k9s }}" "k9s" completion zsh > "$COMP_DIR/_k9s"

generate_comp "{{ $id_pnpm }}" "pnpm" completion zsh > "$COMP_DIR/_pnpm" || true

# [Interop]: HubSpot CLI requires standard output redirection and regex sanitization to remove absolute paths.
echo "  📦 [Completions] Generating for: hs" >&2
echo "#compdef hs" > "$COMP_DIR/_hs"
"$MISE_BIN" exec "{{ $id_hs }}" -- hs completion 2>/dev/null | sed "s|[^[:space:]]*/bin/hs|hs|g" >> "$COMP_DIR/_hs" || true

# [Interop]: Delta requires strict stderr silencing to avoid noise injection into the Zsh completion file.
"$MISE_BIN" exec "{{ $id_delta }}" -- delta --generate-completion zsh 2>/dev/null > "$COMP_DIR/_delta" || true

"{{ .chezmoi.executable }}" completion zsh > "$COMP_DIR/_chezmoi"

# [Architecture]: Intentional Omissions (Zero-Speculation Policy)
# - opentofu: Mutative only (-install-autocomplete). No native stdout generation.
# - tflint: No native completion subcommand.
# - bottom: Bundled assets only.
# - viddy: No verified completion subcommand.

# --- Phase 2: Static Init Generation & Compilation ---
"$MISE_BIN" activate zsh > "$INIT_DIR/mise.zsh"
"$MISE_BIN" exec zoxide -- zoxide init zsh > "$INIT_DIR/zoxide.zsh"
"$MISE_BIN" exec starship -- starship init zsh --print-full-init > "$INIT_DIR/starship.zsh"

for f in "$INIT_DIR"/*.zsh(N); do
  zcompile -U "$f"
done
