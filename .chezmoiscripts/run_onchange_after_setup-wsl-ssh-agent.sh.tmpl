{{ if .is_wsl -}}
#!/bin/zsh
# [chezmoi-script]: Tier 1 (Zsh)
# [Architecture]: WSL2 to Windows SSH Agent Bridge.
# [Rationale]: Dynamically resolves npiperelay path to avoid WinGet vs Windows Store inconsistencies.

set -euo pipefail

echo "🔍 [Identity] Resolving npiperelay.exe path via Windows Interop..."
# [Fact]: Get-Command dynamically locates the binary regardless of the package manager used.
RELAY_BIN_WIN=$(powershell.exe -NoProfile -Command "(Get-Command npiperelay.exe -ErrorAction SilentlyContinue).Source" | tr -d '\r')

if [[ -z "$RELAY_BIN_WIN" ]]; then
  echo "❌ [Error] npiperelay.exe not found in Windows PATH."
  exit 1
fi

RELAY_BIN_WSL=$(wslpath -u "$RELAY_BIN_WIN")

if [[ ! -f "$RELAY_BIN_WSL" ]]; then
  echo "❌ [Error] Resolved npiperelay path does not exist: $RELAY_BIN_WSL"
  exit 1
fi

echo "✅ [Identity] npiperelay resolved at: $RELAY_BIN_WSL"

AGENT_SOCK="{{ .paths.home }}/.1password/agent.sock"
SYSTEMD_DIR="{{ .paths.xdg_config }}/systemd/user"
mkdir -p "$SYSTEMD_DIR"

cat << EOF > "$SYSTEMD_DIR/1password-bridge.service"
[Unit]
Description=1Password SSH Agent Bridge (WSL2 to Windows)
After=network.target
StartLimitIntervalSec=0

[Service]
ExecStartPre=/usr/bin/rm -f "$AGENT_SOCK"
ExecStart=/usr/bin/socat UNIX-LISTEN:"$AGENT_SOCK",fork EXEC:"'$RELAY_BIN_WSL' -ei -s //./pipe/openssh-ssh-agent",nofork
Restart=always
RestartSec=5

[Install]
WantedBy=default.target
EOF

systemctl --user daemon-reload
systemctl --user enable --now 1password-bridge.service
echo "✅ [Identity] 1Password SSH Agent Bridge activated."
{{ end -}}
