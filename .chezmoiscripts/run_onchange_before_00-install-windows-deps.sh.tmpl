{{ if .is_wsl -}}
#!/bin/sh
# [chezmoi-script]: L0 (POSIX Shell) Tiering
# [Architecture]: Declarative Infrastructure via Schema Injection
# [Rationale]: Abstracts package installation using '.chezmoidata/packages.yaml'.
# [Trigger]: Schema Hash: {{ include ".chezmoidata/packages.yaml" | sha256sum }}

set -eu

echo "🔄 [Infrastructure] Updating WinGet package sources..."
# [Rationale]: Ensures the local manifest cache is as fresh as possible to minimize hash drift.
winget.exe source update > /dev/null 2>&1 || true

# --- Standard Package Installer ---
install_winget_app() {
  app_id=$1
  if ! winget.exe list --id "$app_id" > /dev/null 2>&1; then
    echo "📦 [Infrastructure] Installing $app_id on Windows..."
    winget.exe install --id "$app_id" --silent --accept-package-agreements --accept-source-agreements
  else
    echo "✅ [Infrastructure] $app_id is already installed on Windows."
  fi
}

# --- Volatile Package Installer (Nightly/Unstable) ---
# [Architecture]: Error-trapping wrapper for packages requiring hash validation bypass.
install_winget_volatile() {
  app_id=$1
  if ! winget.exe list --id "$app_id" > /dev/null 2>&1; then
    echo "📦 [Infrastructure] Installing Volatile Package: $app_id..."

    # [Rationale]: Temporarily suspend 'set -e' to gracefully trap WinGet security restriction errors.
    set +e
    winget.exe install --id "$app_id" --silent --accept-package-agreements --accept-source-agreements --ignore-security-hash
    WINGET_STATUS=$?
    set -e

    if [ "$WINGET_STATUS" -ne 0 ]; then
      echo "❌ [Security Conflict] WinGet failed to install volatile package '$app_id' (Exit: $WINGET_STATUS)."
      # Exit 2 indicates the InstallerHashOverride policy is disabled on the Host OS.
      if [ "$WINGET_STATUS" -eq 2 ]; then
        echo "👉 Action Required (Run as Administrator in Windows PowerShell):"
        echo "   winget settings --enable InstallerHashOverride"
        echo "   (After enabling, return to WSL and re-run 'chezmoi apply -v')"
      fi
      exit "$WINGET_STATUS"
    fi
  else
    echo "✅ [Infrastructure] $app_id is already installed on Windows."
  fi
}

echo "📦 [Infrastructure] Provisioning Windows dependencies..."

{{ range .packages.windows.winget -}}
{{- /* [Architecture]: Volatile Package Routing */ -}}
{{- if eq . "wez.wezterm.nightly" }}
install_winget_volatile {{ . | quote }}
{{- else }}
install_winget_app {{ . | quote }}
{{- end }}
{{ end -}}

echo "✅ [Infrastructure] Windows dependency provisioning complete."
{{ end -}}
