#!/bin/zsh
# =============================================================================
# [Architecture]: Sovereign Identity Trust Aggregation (Phase 51)
# [Rationale]: Maps dynamically generated keys to their respective Git emails.
# [Reference]: https://man.openbsd.org/ssh-keygen#ALLOWED_SIGNERS
# [Trigger]: {{ .ssh_keys_hash }}
# =============================================================================

set -euo pipefail

ALLOWED_SIGNERS="{{ .paths.xdg_config }}/git/allowed_signers"
mkdir -p "$(dirname "$ALLOWED_SIGNERS")"
TEMP_SIGNERS=$(mktemp)

echo "🔐 [Identity] Generating Git allowed_signers for {{ len .identities }} identities..."

{{ $home := .paths.home -}}
{{ range .identities -}}
{{   $email := .email -}}
PUBKEY_FILE="{{ $home }}/.ssh/id_{{ .key_type }}_{{ .vault_id }}_{{ .item_id }}.pub"
if [[ -f "$PUBKEY_FILE" ]]; then
  key_type=$(awk '{print $1}' "$PUBKEY_FILE")
  key_blob=$(awk '{print $2}' "$PUBKEY_FILE")

  if [[ -n "$key_type" ]] && [[ -n "$key_blob" ]]; then
    echo "{{ $email }} namespaces=\"git\" $key_type $key_blob" >> "$TEMP_SIGNERS"
  else
    echo "⚠️  [Identity] Invalid public key format in $PUBKEY_FILE. Skipping." >&2
  fi
fi
{{ end -}}

{{ if not .identities -}}
# [Architecture]: Graceful fallback for uninitialized CI environments.
echo "ci-bot@example.com namespaces=\"git\" ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAI_CI_FALLBACK_KEY_STUB" >> "$TEMP_SIGNERS"
{{ end -}}

# [Architecture]: Idempotent enforcement using sort -u to guarantee uniqueness.
if [[ -s "$TEMP_SIGNERS" ]]; then
  sort -u "$TEMP_SIGNERS" > "$ALLOWED_SIGNERS"
else
  : > "$ALLOWED_SIGNERS"
fi

rm -f "$TEMP_SIGNERS"
chmod 644 "$ALLOWED_SIGNERS"
echo "✅ [Identity] allowed_signers updated successfully."
