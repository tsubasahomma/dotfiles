#!/bin/zsh
{{ "" -}}
# Phase 52 syncs the rendered WezTerm config to the Windows host.
# [Trigger]: WezTerm Config Hash: {{ include "dot_config/wezterm/wezterm.lua.tmpl" | sha256sum }}

set -euo pipefail

{{ if .is_wsl -}}
if [[ "${CI:-false}" == "true" ]]; then
  echo "⏭️  [Infrastructure] Skipping WezTerm sync in CI."
  exit 0
fi

WIN_HOME=$(powershell.exe -NoProfile -NonInteractive -Command '[Console]::Write($env:USERPROFILE)' | tr -d '\r')
DST_CONFIG_WIN="$(wslpath -u "$WIN_HOME")/.wezterm.lua"

SRC_CONFIG="{{ .paths.xdg_config }}/wezterm/wezterm.lua"
if [[ -f "$SRC_CONFIG" ]]; then
  echo "🌉 [Infrastructure] Syncing WezTerm configuration to Windows..."
  mkdir -p "$(dirname "$DST_CONFIG_WIN")"
  cp -f "$SRC_CONFIG" "$DST_CONFIG_WIN"
fi
{{- end }}
