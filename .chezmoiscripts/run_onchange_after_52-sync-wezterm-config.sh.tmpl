#!/bin/zsh
{{ "" -}}
# Phase 52 delegates rendered WezTerm Windows sync to mise.
# [Trigger]: WezTerm Config Hash: {{ include "dot_config/wezterm/wezterm.lua.tmpl" | sha256sum }}

set -euo pipefail

{{ if .is_wsl -}}
if [[ "${CI:-false}" == "true" ]]; then
  echo "⏭️  [Infrastructure] Skipping WezTerm sync in CI."
  exit 0
fi

echo "⚡ [Delegate] Invoking mise task: sync:wezterm"
exec "{{ .paths.mise }}" run sync:wezterm
{{- end }}
