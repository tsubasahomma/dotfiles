{{- /* [Reference]: https://developer.1password.com/docs/ssh/integrations/wsl/ */ -}}
{{- /* [Reference]: https://www.chezmoi.io/user-guide/password-managers/1password/ */ -}}

sourceDir = {{ .chezmoi.sourceDir | quote }}

{{- /* --- 1. Platform & Interop Initialization --- */}}
{{- $osid := .chezmoi.os -}}
{{- $arch := .chezmoi.arch -}}
{{- $home := .chezmoi.homeDir -}}
{{- $is_wsl := false -}}
{{- if and (eq $osid "linux") (hasKey .chezmoi.kernel "osrelease") -}}
{{-   if contains "microsoft" (.chezmoi.kernel.osrelease | lower)}}{{$is_wsl = true}}{{end -}}
{{- end -}}

{{- $windows_user := "unknown" -}}
{{- $npiperelay_wsl := "" -}}
{{- if $is_wsl -}}
{{-   $windows_user = env "WINDOWS_USER" | default (output "sh" "-c" "cmd.exe /c 'echo %USERNAME%' 2>/dev/null || echo 'unknown'" | trim) -}}
{{-   $win_npiperelay := output "powershell.exe" "-NoProfile" "-NonInteractive" "-Command" "(Get-Command npiperelay.exe -ErrorAction SilentlyContinue).Source | Write-Host -NoNewline" -}}
{{-   if ne $win_npiperelay "" -}}
{{-     $npiperelay_wsl = output "wslpath" "-u" $win_npiperelay | trim -}}
{{-   end -}}
{{- end -}}

{{- $brew_prefix := "/usr/local" -}}
{{- if eq $osid "darwin" -}}
{{-   if eq $arch "arm64" }}{{$brew_prefix = "/opt/homebrew"}}{{end -}}
{{- else if eq $osid "linux" -}}
{{-   $brew_prefix = "/home/linuxbrew/.linuxbrew" -}}
{{- end -}}

{{- /* --- 2. Identity prerequisite checks (Tier -2 assertion) --- */}}
{{- $local_bin := joinPath $home ".local/bin" -}}
{{- $mise_bin := joinPath $local_bin "mise" -}}
{{- if not (stat $mise_bin) -}}
{{-   $mise_bin = lookPath "mise" | default $mise_bin -}}
{{- end -}}

{{- /* Resolve op binary path from the current platform without guessing. */}}
{{- $op_bin := "" -}}
{{- if $is_wsl -}}
{{-   $win_op := output "powershell.exe" "-NoProfile" "-NonInteractive" "-Command" "(Get-Command op.exe -ErrorAction SilentlyContinue).Source | Write-Host -NoNewline" -}}
{{-   if ne $win_op ""}}{{$op_bin = output "wslpath" "-u" $win_op | trim}}{{end -}}
{{- else -}}
{{-   $op_bin = lookPath "op" -}}
{{- end -}}

{{- /* [Assertion]: 1Password CLI is a Tier -2 prerequisite. */}}
{{- if and (not (env "CI")) (eq $op_bin "") -}}
{{-   fail "[FATAL] 1Password CLI ('op') not found. Please install it manually before running chezmoi." -}}
{{- end -}}

{{- $op_status := "locked" -}}
{{- if ne $op_bin "" -}}
{{-   $op_status = output "sh" "-c" (printf "'%s' account get >/dev/null 2>&1 && echo 'ready' || echo 'locked'" $op_bin) | trim -}}
{{- end -}}

{{- /* [Assertion]: 1Password session must be authenticated. */}}
{{- if and (not (env "CI")) (eq $op_status "locked") -}}
{{-   fail "[FATAL] 1Password session is locked. Run 'op signin' and try again." -}}
{{- end -}}

{{- /* --- 3. Content-Addressable Identity Aggregation --- */}}
{{- $identities := list -}}
{{- $ssh_keys_hash_input := "" -}}
{{- if eq $op_status "ready" -}}
{{-   $accounts_json := output $op_bin "account" "list" "--format" "json" -}}
{{-   if ne $accounts_json "" -}}
{{-     $accounts := fromJson $accounts_json -}}
{{-     range $accounts -}}
{{-       $account_id := .account_uuid -}}
{{-       $items_json := output $op_bin "item" "list" "--tags" "dotfiles-ssh-key" "--account" $account_id "--format" "json" -}}
{{-       if and (ne $items_json "") (ne $items_json "[]") -}}
{{-         $items := fromJson $items_json -}}
{{-         $ssh_keys_hash_input = printf "%s%s" $ssh_keys_hash_input $items_json -}}
{{-         range $items -}}
{{-           $item_id := .id -}}
{{-           $details := fromJson (output $op_bin "item" "get" $item_id "--account" $account_id "--format" "json") -}}
{{-           $git_name := "" -}}
{{-           $git_email := "" -}}
{{-           $git_dirs := "" -}}
{{-           $key_type := "ed25519" -}}
{{-           $public_key := "" -}}
{{-           range $details.fields -}}
{{-             if and (hasKey . "section") (eq .section.label "dotfiles") -}}
{{-               if eq .label "dotfiles_git_name" }}{{ $git_name = .value }}{{ end -}}
{{-               if eq .label "dotfiles_git_email" }}{{ $git_email = .value }}{{ end -}}
{{-               if eq .label "dotfiles_git_dirs" }}{{ $git_dirs = .value }}{{ end -}}
{{-             end -}}
{{-             if eq .label "key type" }}{{ $key_type = .value }}{{ end -}}
{{-             if eq .label "public key" }}{{ $public_key = .value }}{{ end -}}
{{-           end -}}
{{-           if and (ne $git_name "") (ne $git_email "") (ne $git_dirs "") (ne $public_key "") -}}
{{-             $key_hash := substr 0 8 (sha256sum $public_key) -}}
{{-             $identities = append $identities (dict "item_id" $item_id "account_id" $account_id "key_hash" $key_hash "key_type" (lower $key_type) "name" $git_name "email" $git_email "dirs" $git_dirs "public_key" $public_key) -}}
{{-           end -}}
{{-         end -}}
{{-       end -}}
{{-     end -}}
{{-   end -}}
{{- end -}}

{{- $ssh_keys_hash := "none" -}}
{{- if ne $ssh_keys_hash_input "" -}}
{{-   $ssh_keys_hash = sha256sum $ssh_keys_hash_input -}}
{{- end -}}

{{- /* --- 4. Tool & SSH Context Resolver --- */}}
{{- $ssh_auth_sock := "" -}}
{{- if eq $osid "darwin" -}}
{{-   $ssh_auth_sock = joinPath $home "Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock" -}}
{{- else if $is_wsl -}}
{{-   $ssh_auth_sock = joinPath $home ".1password/agent.sock" -}}
{{- end -}}

{{- /* Resolve the SSH signing helper for the current platform. */ -}}
{{- $op_sign := "" -}}
{{- if eq $osid "darwin" -}}
{{-   $op_sign = "/Applications/1Password.app/Contents/MacOS/op-ssh-sign" -}}
{{- else if $is_wsl -}}
{{-   $win_op_sign := output "powershell.exe" "-NoProfile" "-NonInteractive" "-Command" "foreach ($cmd in 'op-ssh-sign-wsl.exe', 'op-ssh-sign.exe') { $p = (Get-Command $cmd -ErrorAction SilentlyContinue).Source; if ($p) { Write-Host -NoNewline $p; break } }" -}}
{{-   if ne $win_op_sign ""}}{{$op_sign = output "wslpath" "-u" $win_op_sign | trim}}{{end -}}
{{- else -}}
{{-   $op_sign = lookPath "op-ssh-sign" | default "" -}}
{{- end -}}

{{- $true_cmd := lookPath "true" | default "/usr/bin/true" }}

[data]
    osid = {{ $osid | quote }}
    arch = {{ $arch | quote }}
    is_wsl = {{ $is_wsl }}
    npiperelay_wsl = {{ $npiperelay_wsl | quote }}
    brew_prefix = {{ $brew_prefix | quote }}
    windows_user = {{ $windows_user | quote }}
    ssh_auth_sock = {{ $ssh_auth_sock | quote }}
    op_status = {{ $op_status | quote }}
    ssh_keys_hash = {{ $ssh_keys_hash | quote }}
    identities = [
    {{- range $i, $id := $identities -}}
      {{- if $i }},{{ end -}}
      { item_id = {{ $id.item_id | quote }}, account_id = {{ $id.account_id | quote }}, key_hash = {{ $id.key_hash | quote }}, key_type = {{ $id.key_type | quote }}, name = {{ $id.name | quote }}, email = {{ $id.email | quote }}, dirs = {{ $id.dirs | quote }}, public_key = {{ $id.public_key | quote }} }
    {{- end -}}
    ]

    [data.paths]
        home = {{ $home | quote }}
        op = {{ $op_bin | quote }}
        mise = {{ $mise_bin | quote }}
        xdg_config = {{ joinPath $home ".config" | quote }}
        xdg_data = {{ joinPath $home ".local/share" | quote }}
        xdg_state = {{ joinPath $home ".local/state" | quote }}
        xdg_cache = {{ joinPath $home ".cache" | quote }}
        true_cmd = {{ $true_cmd | quote }}
        op_sign = {{ $op_sign | quote }}

[edit]
    command = "nvim"

[hooks.read-source-state.pre]
    command = "{{ .chezmoi.sourceDir }}/.bootstrap-identity.sh"
