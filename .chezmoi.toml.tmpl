{{/* [Architecture]: Foundation Schema | Phase 20.9 Resilience First Edition */}}
{{/* [Reference]: https://www.chezmoi.io/user-guide/templating/ */}}

{{$osid := .chezmoi.os}}
{{$arch := .chezmoi.arch}}
{{$home := .chezmoi.homeDir}}

{{$is_wsl := false}}
{{if and (eq $osid "linux") (hasKey .chezmoi.kernel "osrelease")}}
{{  if contains "microsoft" (.chezmoi.kernel.osrelease | lower)}}{{$is_wsl = true}}{{end}}
{{end}}

{{/* [Architecture]: Persistent Interop Cache (Zero-Latency Windows Hook) */}}
{{$windows_user := "unknown"}}
{{if hasKey . "windows_user"}}
{{  $windows_user = .windows_user}}
{{else if $is_wsl}}
{{  $windows_user = output "powershell.exe" "-NoProfile" "-Command" "echo $env:USERNAME" | trim}}
{{end}}

{{$brew_prefix := "/usr/local"}}
{{if eq $osid "darwin"}}
{{  if eq $arch "arm64" }}{{$brew_prefix = "/opt/homebrew"}}{{end}}
{{else if eq $osid "linux"}}
{{  $brew_prefix = "/home/linuxbrew/.linuxbrew"}}
{{end}}

{{$local_bin := joinPath $home ".local/bin"}}
{{$op_bin := lookPath "op" | default (joinPath $local_bin "op")}}
{{$is_op_present := stat $op_bin}}

{{$op_status := "missing"}}
{{if $is_op_present}}
{{  $op_status = output "sh" "-c" (printf "'%s' account get >/dev/null 2>&1 && echo 'ready' || echo 'locked'" $op_bin) | trim}}
{{end}}

{{$true_cmd := lookPath "true" | default "/usr/bin/true"}}

{{$op_sign := ""}}
{{$ssh_auth_sock := ""}}
{{if eq $osid "darwin"}}
{{  $op_sign = "/Applications/1Password.app/Contents/MacOS/op-ssh-sign"}}
{{  $ssh_auth_sock = joinPath $home "Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"}}
{{else if $is_wsl}}
{{  $op_sign = joinPath "/mnt/c/Users" $windows_user "AppData/Local/Microsoft/WindowsApps/op-ssh-sign-wsl.exe"}}
{{  $ssh_auth_sock = joinPath $home ".1password/agent.sock"}}
{{end}}

{{/* Default values for Bootstrap Mode */}}
{{$gh_user := "pending"}}
{{$name := "Pending Identity"}}
{{$email := "pending@example.com"}}
{{$link_id := "pending"}}
{{$vault_id := "unknown"}}
{{$ssh_keys_hash := "none"}}
{{$is_sovereign := false}}

{{/* [Architecture]: Single-Pass Identity Resolution (Sovereign Account Anchor) */}}
{{if eq $op_status "ready"}}
{{  $profile_list := output "sh" "-c" (printf "'%s' item list --tags dotfiles-github-profile --format json 2>/dev/null || echo '[]'" $op_bin) | fromJson}}
{{  if gt (len $profile_list) 0}}
{{    $profile_id := (index $profile_list 0).id}}
{{    $profile := output "sh" "-c" (printf "'%s' item get %s --format json" $op_bin $profile_id) | fromJson}}
{{    $vault_id = $profile.vault.id}}
{{    range $profile.fields}}
{{      if hasKey . "label"}}
{{        if eq .label "dotfiles_gh_user" }}{{$gh_user = .value}}{{$is_sovereign = true}}{{end}}
{{        if eq .label "dotfiles_gh_name" }}{{$name = .value}}{{end}}
{{        if eq .label "dotfiles_gh_email"}}{{$email = .value}}{{end}}
{{        if eq .label "dotfiles_link_id" }}{{$link_id = .value}}{{end}}
{{      end}}
{{    end}}

{{/* O(1) Hash Generation for SSH keys from the active Sovereign Account */}}
{{    $ssh_keys := output "sh" "-c" (printf "'%s' item list --tags dotfiles-ssh-key --format json 2>/dev/null || echo '[]'" $op_bin) | fromJson}}
{{    $ssh_keys_hash = sha256sum (toJson $ssh_keys)}}
{{  end}}
{{end}}

# --- Foundation Schema ---
[data]
    osid = {{$osid | quote}}
    arch = {{$arch | quote}}
    is_wsl = {{$is_wsl}}
    brew_prefix = {{$brew_prefix | quote}}
    windows_user = {{$windows_user | quote}}
    ssh_auth_sock = {{$ssh_auth_sock | quote}}
    op_status = {{$op_status | quote}}

    gh_user = {{$gh_user | quote}}
    name = {{$name | quote}}
    email = {{$email | quote}}
    link_id = {{$link_id | quote}}

    ssh_keys_hash = {{$ssh_keys_hash | quote}}
    ssh_key_name = {{printf "id_ed25519_%s_%s.pub" $vault_id $link_id | quote}}

    {{if $is_sovereign}}
    gh_root = "src/github.com/{{$gh_user}}"
    {{else}}
    gh_root = "src/github.com/unallocated"
    {{end}}

    [data.paths]
        home = {{$home | quote}}
        op = {{$op_bin | quote}}
        xdg_config = {{(joinPath $home ".config") | quote}}
        xdg_data = {{(joinPath $home ".local/share") | quote}}
        xdg_state = {{(joinPath $home ".local/state") | quote}}
        xdg_cache = {{(joinPath $home ".cache") | quote}}
        mise = {{(joinPath $home ".local/bin/mise") | quote}}
        true_cmd = {{$true_cmd | quote}}
        op_sign = {{$op_sign | quote }}
        ssh_auth_sock = {{$ssh_auth_sock | quote}}

[edit]
    command = "nvim"

# [Architecture]: Pre-flight Execution Hook
[hooks.read-source-state.pre]
    command = "{{ .chezmoi.sourceDir }}/.bootstrap-identity.sh"

{{if not (env "CI")}}
{{  if ne $op_status "ready"}}
# [Next Action]: 1Password authentication is required.
# 1. Open the 1Password Desktop App and enable "Integrate with 1Password CLI" in Settings > Developer.
# 2. Run 'op signin' to authenticate, then run 'chezmoi apply' again.
{{  else}}
# [System]: Sovereign Identity ({{$gh_user}}) successfully loaded.
{{  end}}
{{end}}
