{{- /* [Reference]: https://www.chezmoi.io/reference/special-files/chezmoiignore/ */ -}}
{{/*
Source-only maintainer note:
Ignore dynamic target files while preserving directories that chezmoi manages declaratively.
*/}}

# --- 1. Secret & Cryptographic Boundaries ---
**/.ssh/id_*
**/.ssh/*.pub
**/.ssh/known_hosts*
**/.ssh/*.backup
.gnupg/**
{{/* Ignore dynamic socket noise but preserve the base directory. */}}
.1password/**
!.1password/
!.1password/.keep

# --- 2. Transient Cache & State Directories ---
{{/*
Declarative directory structure is managed through .keep files.
Generated files inside these directories are ignored.
*/}}
.cache/**
!.cache/
!.cache/zsh/
!.cache/zsh/.keep

.local/share/pnpm/**
!.local/share/pnpm/
!.local/share/pnpm/.keep

.local/state/**
!.local/state/
!.local/state/ssh/
!.local/state/ssh/sockets/
!.local/state/ssh/sockets/.keep
!.local/state/zsh/
!.local/state/zsh/.keep
!.local/state/python/
!.local/state/python/.keep
!.local/state/node/
!.local/state/node/.keep

# --- 3. Dynamic Artifacts & Noise ---
.DS_Store
Thumbs.db
**/*.log
**/.*_history
**/.zcompdump*
package-lock.json
pnpm-lock.yaml

# --- 4. Repository Orchestration (Strict Isolation) ---
{{/* Do not deploy repository management files to $HOME. */}}
README.md
LICENSE
ARCHITECTURE.md
AGENTS.md
docs/**
.github/**
.context/repomix/**
repomix-*.xml
repomix.config.json
.editorconfig
.gitattributes
.gitignore
.pre-commit-config.yaml
renovate.json5
.mise.toml

# --- 5. OS-Specific Overrides ---
{{ if ne .osid "darwin" -}}
{{- if not .is_wsl }}
{{/*
The WezTerm launcher shim is only valid on macOS and WSL.
Plain Linux and CI runners should not manage this target.
*/}}
.local/bin/wezterm
{{- end }}
Library/**
{{ end -}}
