{{- /* [Reference]: https://www.chezmoi.io/reference/special-files/chezmoiignore/ */ -}}
# =============================================================================
# 1. Secret & Identity Protection (Zero-Leak)
# =============================================================================
**/.ssh/id_*
**/.ssh/*.pub
**/.ssh/known_hosts*
**/.ssh/*.backup
.1password
.gnupg

# =============================================================================
# 2. Infrastructure Whitelist
# =============================================================================
# [Rationale]: Ensure essential state directories are NOT ignored so chezmoi
# can manage directory structures (like SSH sockets).
!.local/state/ssh/
!.local/state/ssh/sockets/
!.local/state/ssh/sockets/.keep

# =============================================================================
# 3. System & Temporary Noise (Global Patterns)
# =============================================================================
.DS_Store
Thumbs.db
**/*.log
**/*.history
**/*_history
**/.zcompdump*
.cache/**

# [Rationale]: Exclude ephemeral lockfiles from being managed or applied to $HOME.
package-lock.json
pnpm-lock.yaml

# =============================================================================
# 4. Repository Meta & Tier 0 Isolation
# =============================================================================
# [Architecture]: Protect Sovereign Tier 0 boundaries.
.mise.toml

README.md
LICENSE
ARCHITECTURE.md
.github
repomix*

# =============================================================================
# 5. OS-Specific Isolation
# =============================================================================
{{ if ne .osid "darwin" -}}
Library
{{ end -}}
