[user]
    # [LLM Context]: user.email is intentionally omitted here to enforce Identity-driven Routing.
    # It is injected dynamically based on directory context via includeIf below.
    name = {{ .name | quote }}

[commit]
    gpgsign = true

[tag]
    gpgsign = true

[gpg]
    format = ssh
    # [Rationale]: Null-GPG Protocol. Silences execution errors for unmanageable PGP signatures (e.g., GitHub Web Merges)
    program = {{ .paths.true_cmd | quote }}

[gpg "ssh"]
    program = {{ .paths.op_sign | quote }}
    allowedSignersFile = {{ (joinPath .paths.xdg_config "git/allowed_signers") | quote }}

[core]
    editor = nvim
    pager = delta
    fsmonitor = true
    untrackedCache = true
    ignorecase = false
    precomposeunicode = true

[index]
    threads = true

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    side-by-side = true
    line-numbers = true
    syntax-theme = Catppuccin Mocha

[merge]
    conflictstyle = zdiff3

[diff]
    colorMoved = default
    algorithm = patience

[pull]
    rebase = true

[fetch]
    prune = true

[push]
    autoSetupRemote = true
    followTags = true

[rebase]
    autoStash = true
    updateRefs = true

[init]
    defaultBranch = main

[column]
    ui = auto

[branch]
    sort = -committerdate

[alias]
    st = status -sb
    last = log -1 HEAD --stat
    fix = !git-absorb
    amend = commit --amend --no-edit
    lg = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit --date=relative
    adog = log --graph --all --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit --date=relative

# ================================================================
# Context-Aware Identity Routing (Policy Layer)
# ================================================================

# [Rationale]: "The Safe Zone".
# Forces the Personal Sovereign Identity (and its SSH Key) for repositories inside the gh_root.
[includeIf "gitdir:{{ .paths.home }}/{{ .gh_root }}/**"]
    path = {{ (joinPath .paths.xdg_config "git/config_personal") | quote }}

[includeIf "gitdir:{{ .chezmoi.sourceDir }}/**"]
    path = {{ (joinPath .paths.xdg_config "git/config_personal") | quote }}

# [Rationale]: "The Escape Hatch".
# Unmanaged zones (like work projects) are handled by manual local configs.
[include]
    path = ~/.gitconfig.local
