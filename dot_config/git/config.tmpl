# [Architecture]: Zero-Trust Git Configuration (Parallel Identity Model)

[user]
    # [Security]: Global identity variables are strictly prohibited.
    # Identity is deterministically routed via includeIf based on directory context.

[commit]
    gpgsign = true

[tag]
    gpgsign = true

[gpg]
    format = ssh
    # [Rationale]: Null-GPG Protocol. Silences execution errors for unmanageable PGP signatures (e.g., GitHub Web Merges)
    program = {{ .paths.true_cmd | quote }}

[gpg "ssh"]
    program = {{ .paths.op_sign | quote }}
    allowedSignersFile = {{ (joinPath .paths.xdg_config "git/allowed_signers") | quote }}

[core]
    editor = nvim
    pager = delta
    fsmonitor = true
    untrackedCache = true
    ignorecase = false
    precomposeunicode = true

[index]
    threads = true

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    side-by-side = true
    line-numbers = true
    syntax-theme = Catppuccin Mocha

[merge]
    conflictstyle = zdiff3

[diff]
    colorMoved = default
    algorithm = patience

[pull]
    rebase = true

[fetch]
    prune = true

[push]
    autoSetupRemote = true
    followTags = true

[rebase]
    autoStash = true
    updateRefs = true

[init]
    defaultBranch = main

[column]
    ui = auto

[branch]
    sort = -committerdate

[alias]
    st = status -sb
    last = log -1 HEAD --stat
    fix = !git-absorb
    amend = commit --amend --no-edit
    lg = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit --date=relative
    adog = log --graph --all --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit --date=relative

# ================================================================
# Context-Aware Identity Routing (Policy Layer)
# ================================================================

{{- $home := .paths.home }}
{{- $xdg_config := .paths.xdg_config }}
{{- range .identities }}
{{-   $name := .name }}
{{-   $email := .email }}
{{-   $id_str := printf "%s_%s" .vault_id .item_id }}
{{-   $config_path := joinPath $xdg_config (printf "git/identities/config_%s" $id_str) }}
{{-   $dirs := splitList "," .dirs }}
{{-   range $dirs }}
{{-     $normalized_dir := trim . }}
{{-     if hasPrefix "~/" $normalized_dir }}
{{-       $normalized_dir = joinPath $home (trimPrefix "~/" $normalized_dir) }}
{{-     end }}
# [Policy]: {{ $name }} ({{ $email }})
[includeIf "gitdir:{{ $normalized_dir }}/**"]
    path = {{ $config_path | quote }}
{{-   end }}
{{- end }}
