local wezterm = require("wezterm")
local config = wezterm.config_builder()

local scheme = wezterm.get_builtin_color_schemes()["Kanagawa Dragon (Gogh)"]
config.colors = scheme

-- [Architecture]: Font Fallback Chain
-- [Rationale]: Ensure deterministic Japanese rendering across OS boundaries without relying on host OS default fallbacks.
-- [Reference]: https://wezfurlong.org/wezterm/config/lua/wezterm/font_with_fallback.html
config.font = wezterm.font_with_fallback({
  "JetBrainsMono Nerd Font",
  "BIZ UD Gothic",
  "IBM Plex Sans JP",
  "Hiragino Sans",
  "Meiryo",
})

config.font_size = 14.0
config.line_height = 1.15
config.front_end = "WebGpu"
config.window_background_opacity = 1.0
config.window_padding = {
  left = 12,
  right = 12,
  top = 10,
  bottom = 8,
}
config.hide_tab_bar_if_only_one_tab = true
config.bold_brightens_ansi_colors = true

-- [Architecture]: WSL Integration for Windows Hosts
-- [Rationale]: WezTerm on Windows defaults to the native host shell (cmd.exe).
-- We explicitly set the default domain to WSL to ensure the 'Eternal Platform'
-- (Zsh environment) is the entry point.
-- The distribution name 'Ubuntu' is confirmed via host APT logs (jammy).
if wezterm.target_triple:find("windows") then
  config.default_domain = "WSL:Ubuntu"
end

return config
