# Declarative package list for the macOS workstation.
# [Reference]: https://www.chezmoi.io/user-guide/advanced/install-packages-declaratively/

# --- Headless Infrastructure (Always Provisioned) ---
{{ range .packages.headless.common -}}
brew {{ . | quote }}
{{ end -}}

{{ range .packages.headless.darwin.brews -}}
brew {{ . | quote }}
{{ end -}}

{{ range .packages.headless.darwin.casks -}}
cask {{ . | quote }}
{{ end -}}

{{- if not (env "CI") }}
# =============================================================================
# Desktop & Media Provisioning (Bypassed in CI)
# =============================================================================

# --- Media Processing ---
{{ range .packages.media.darwin -}}
brew {{ . | quote }}
{{ end -}}

# --- GUI Applications ---
{{ range .packages.gui.darwin -}}
cask {{ . | quote }}
{{ end -}}
{{- end }}
