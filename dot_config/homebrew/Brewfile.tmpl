# [Rationale]: Declarative infrastructure for macOS workstation (2026).
# Homebrew is strictly limited to OS-level system dependencies and GUI Casks.
# [Reference]: https://www.chezmoi.io/user-guide/advanced/install-packages-declaratively/

# --- Common & System Cryptography ---
{{ range .packages.common -}}
brew {{ . | quote }}
{{ end -}}
{{ range .packages.darwin.brews -}}
brew {{ . | quote }}
{{ end }}

{{- if not (env "CI") }}
# --- Media & Document Processing (Non-CI) ---
{{ range .packages.darwin.media -}}
brew {{ . | quote }}
{{ end -}}
{{- end }}

# --- Casks (GUI Apps & Fonts) ---
{{ range .packages.darwin.casks -}}
cask {{ . | quote }}
{{ end -}}
