#!/usr/bin/env bash
# [MISE] description="System Health Check & Self-Healing Engine"
{{/* [Reference]: https://mise.jdx.dev/tasks/file-tasks.html */}}{{ "" -}}
{{/* [Reference]: https://www.chezmoi.io/user-guide/password-managers/1password/ */}}{{ "" -}}
{{/* [chezmoi-script]: L0 (Bash) Tiering */}}{{ "" -}}
{{/* [Rationale]: Self-healing diagnostic engine with environment-aware validation. */}}{{ "" -}}
{{/* [Architecture]: Strict Bash interpreter to ensure compatibility with '[[' syntax across Ubuntu/macOS. */}}{{ "" -}}
set -euo pipefail

GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

log_ok() { printf "  ${GREEN}✅ %s${NC}\n" "$1"; }
log_warn() { printf "  ${YELLOW}⚠️  %s${NC}\n" "$1"; }
log_err() { printf "  ${RED}❌ %s${NC}\n" "$1"; }
log_guide() { printf "  ${BLUE}👉 %s${NC}\n" "$1"; }

IS_CI="${CI:-false}"
HOME_DIR="{{ .paths.home }}"
OP_BIN="{{ .paths.op }}"
MISE_BIN="{{ .paths.mise }}"
HAS_ERROR=0

echo "--- 1. Infrastructure Security & Permissions ---"
for dir in "$HOME_DIR/.ssh" "{{ .paths.xdg_state }}/ssh"; do
  if [[ -d "$dir" ]]; then
    chmod 700 "$dir"
    log_ok "Permissions secured for $dir (0700)."
  fi
done

echo "--- 2. Identity & Auth Bridge Analysis ---"
if "$OP_BIN" account get > /dev/null 2>&1; then
  log_ok "1Password session authenticated."

  {{- if .identities }}
  {{- range .identities }}
  ID_CONF="{{ $.paths.xdg_config }}/git/identities/config_{{ .email }}_{{ .key_hash }}"
  if [[ -f "$ID_CONF" ]]; then
    AUTH_EMAIL=$(git config -f "$ID_CONF" user.email 2>/dev/null || echo "")
    if [[ "$AUTH_EMAIL" == "{{ .email }}" ]]; then
      log_ok "Identity binding verified: {{ .name }} ($AUTH_EMAIL)"
    else
      log_err "Identity binding mismatch for {{ .name }} (Expected: {{ .email }}, Found: $AUTH_EMAIL)."
      HAS_ERROR=1
    fi
  else
    log_err "Scoped Git configuration missing at $ID_CONF."
    log_guide "chezmoi apply"
    HAS_ERROR=1
  fi
  {{- end }}
  {{- else }}
  log_warn "No identities mapped from 1Password schema."
  {{- end }}
else
  if [[ "$IS_CI" == "true" ]]; then
    log_ok "Automation Mode: Sovereign Identity verification bypassed."
  else
    log_err "Sovereign Identity is locked or unreachable."
    log_guide "$OP_BIN signin"
    HAS_ERROR=1
  fi
fi

echo "--- 3. SSH Agent & Cryptographic Trust ---"
if ssh-add -l > /dev/null 2>&1; then
  log_ok "SSH Agent is responsive and active."
else
  if [[ "$IS_CI" == "true" ]]; then
    log_warn "SSH Agent unresponsive (expected in CI environment)."
  else
    log_warn "SSH Agent unresponsive. Attempting bridge recovery..."
    {{ if .is_wsl }}
    if command -v systemctl >/dev/null 2>&1; then
      systemctl --user restart 1password-bridge.service || true
    fi
    {{ end }}
    sleep 1
    if ssh-add -l > /dev/null 2>&1; then
      log_ok "Authentication bridge recovered successfully."
    else
      log_err "Authentication bridge failed to initialize."
      log_guide "Verify the 'SSH Agent' setting in 1Password Desktop App."
      HAS_ERROR=1
    fi
  fi
fi

echo "--- 4. Neovim Deterministic State ---"
LOCK_FILE="{{ .paths.xdg_config }}/nvim/lazy-lock.json"
if [[ -f "$LOCK_FILE" ]]; then
  if chezmoi verify "$LOCK_FILE" >/dev/null 2>&1; then
    log_ok "Neovim lockfile (lazy-lock.json) is synchronized."
  else
    log_warn "Neovim lockfile drift detected. Ensure you run 'mise run update:lazy-lock' to commit changes."
    if [[ "$IS_CI" != "true" ]]; then HAS_ERROR=1; fi
  fi
else
  log_err "Neovim lockfile is missing."
  log_guide "mise run integrate:nvim && chezmoi add $LOCK_FILE"
  HAS_ERROR=1
fi

# [Architecture]: End-to-End Provider Validation (Neovim 0.12 Spec)
# [Reference]: https://neovim.io/doc/user/provider.html#provider-python
# [Rationale]: Bypasses binary naming speculation (e.g., pynvim vs pynvim-python).
# Executes Neovim's actual provider detection logic to prove the provider
# is present and functional under the user's real runtime configuration.
if command -v nvim >/dev/null 2>&1; then
  if nvim --headless +"lua if vim.fn.has('python3') == 1 then print('PROVIDER_OK') end" +qa 2>&1 | grep -q "PROVIDER_OK"; then
    log_ok "Python Provider is natively recognized and functional in Neovim."
  else
    log_err "Python Provider is dysfunctional or not recognized by Neovim."
    log_guide "Ensure 'pipx:neovim/pynvim' is in tools.yaml and run 'mise install'."
    HAS_ERROR=1
  fi
else
  log_warn "Neovim executable not found in PATH. Skipping provider verification."
fi

echo "--- 5. Prose Linting Engine (Vale) ---"
VALE_CONFIG="{{ .paths.xdg_config }}/vale/vale.ini"
if [[ -f "$VALE_CONFIG" ]]; then
  if "$MISE_BIN" exec vale -- vale --config="$VALE_CONFIG" ls-config > /dev/null 2>&1; then
    log_ok "Vale configuration loaded successfully."

    STYLE_DIR="{{ .paths.xdg_data }}/vale/styles/Google"
    if [[ -d "$STYLE_DIR" ]]; then
      log_ok "External style packages (Google) provisioned."
    else
      log_err "External style packages missing at $STYLE_DIR."
      log_guide "chezmoi apply (or manual: vale --config=\"$VALE_CONFIG\" sync)"
      HAS_ERROR=1
    fi
  else
    log_err "Vale failed to parse configuration at $VALE_CONFIG."
    HAS_ERROR=1
  fi
else
  log_err "Vale configuration missing at $VALE_CONFIG."
  log_guide "chezmoi apply"
  HAS_ERROR=1
fi

echo "--- 6. Toolchain Drift Analysis ---"
if [[ -x "$MISE_BIN" ]]; then
  log_ok "Hermetic mise binary verified."
else
  log_err "mise executable missing."
  log_guide "curl https://mise.run | sh"
  HAS_ERROR=1
fi

if [[ "$IS_CI" != "true" ]]; then
  # [Architecture]: Tiered PATH Precedence Verification
  # [Rationale]: Ensures infrastructure paths (mise/aqua) precede system binaries.
  # Static index-0 checks are avoided to support dynamic mise activation.
  SYS_PATH="/usr/bin"
  LOCAL_BIN="$HOME_DIR/.local/bin"
  if [[ "$PATH" == *"$LOCAL_BIN"* ]] && [[ "${PATH%%$LOCAL_BIN*}" != *"$SYS_PATH"* ]]; then
    log_ok "PATH precedence correctly prioritized (Infrastructure over System)."
  else
    log_warn "PATH precedence violation detected. Infrastructure paths might be shadowed."
    log_guide "Verify your shell initialization order in dot_zshrc."
  fi
fi

printf "\n"
if [[ "$HAS_ERROR" -eq 0 ]]; then
  printf "${GREEN}✨ System Health Evaluation Complete (Zero Drift)${NC}\n"
  exit 0
else
  printf "${RED}❌ System Health Evaluation Failed. Address the errors above.${NC}\n"
  exit 1
fi
