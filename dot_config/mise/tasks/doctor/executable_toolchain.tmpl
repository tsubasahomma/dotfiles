#!/usr/bin/env bash
# [MISE] description="Verify mise availability and PATH precedence"
{{/* [Reference]: https://mise.jdx.dev/tasks/file-tasks.html */}}{{ "" -}}

set -euo pipefail

GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

log_ok() { printf "  ${GREEN}✅ %s${NC}\n" "$1"; }
log_warn() { printf "  ${YELLOW}⚠️  %s${NC}\n" "$1"; }
log_err() { printf "  ${RED}❌ %s${NC}\n" "$1"; }
log_guide() { printf "  ${BLUE}👉 %s${NC}\n" "$1"; }

IS_CI="${CI:-false}"
HOME_DIR="{{ .paths.home }}"
MISE_BIN="{{ .paths.mise }}"
HAS_ERROR=0

echo "--- 6. Toolchain Drift Analysis ---"
if [[ -x "$MISE_BIN" ]]; then
  log_ok "Hermetic mise binary verified."
else
  log_err "mise executable missing."
  log_guide "curl https://mise.run | sh"
  HAS_ERROR=1
fi

if [[ "$IS_CI" != "true" ]]; then
  # Verify PATH precedence for mise and aqua before system binaries.
  # This catches accidental fallback to globally installed tools.
  # Static index-0 checks are avoided to support dynamic mise activation.
  SYS_PATH="/usr/bin"
  LOCAL_BIN="$HOME_DIR/.local/bin"
  if [[ "$PATH" == *"$LOCAL_BIN"* ]] && [[ "${PATH%%$LOCAL_BIN*}" != *"$SYS_PATH"* ]]; then
    log_ok "PATH precedence correctly prioritized (Infrastructure over System)."
  else
    log_warn "PATH precedence violation detected. Infrastructure paths might be shadowed."
    log_guide "Verify your shell initialization order in dot_zshrc."
  fi
fi

exit "$HAS_ERROR"
