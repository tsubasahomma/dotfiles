#!/usr/bin/env bash
# [MISE] description="Verify identity routing and SSH agent health"
{{/* [Reference]: https://mise.jdx.dev/tasks/file-tasks.html */}}{{ "" -}}
{{/* [Reference]: https://www.chezmoi.io/user-guide/password-managers/1password/ */}}{{ "" -}}

set -euo pipefail

GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

log_ok() { printf "  ${GREEN}✅ %s${NC}\n" "$1"; }
log_warn() { printf "  ${YELLOW}⚠️  %s${NC}\n" "$1"; }
log_err() { printf "  ${RED}❌ %s${NC}\n" "$1"; }
log_guide() { printf "  ${BLUE}👉 %s${NC}\n" "$1"; }

IS_CI="${CI:-false}"
OP_BIN="{{ .paths.op }}"
HAS_ERROR=0

echo "--- 2. Identity & Auth Bridge Analysis ---"
if "$OP_BIN" account get > /dev/null 2>&1; then
  log_ok "1Password session authenticated."

  {{- if .identities }}
  {{- range .identities }}
  ID_CONF="{{ $.paths.xdg_config }}/git/identities/config_{{ .email }}_{{ .key_hash }}"
  if [[ -f "$ID_CONF" ]]; then
    AUTH_EMAIL=$(git config -f "$ID_CONF" user.email 2>/dev/null || echo "")
    if [[ "$AUTH_EMAIL" == "{{ .email }}" ]]; then
      log_ok "Identity binding verified: {{ .name }} ($AUTH_EMAIL)"
    else
      log_err "Identity binding mismatch for {{ .name }} (Expected: {{ .email }}, Found: $AUTH_EMAIL)."
      HAS_ERROR=1
    fi
  else
    log_err "Scoped Git configuration missing at $ID_CONF."
    log_guide "chezmoi apply"
    HAS_ERROR=1
  fi
  {{- end }}
  {{- else }}
  log_warn "No identities mapped from 1Password schema."
  {{- end }}
else
  if [[ "$IS_CI" == "true" ]]; then
    log_ok "Automation Mode: Sovereign Identity verification bypassed."
  else
    log_err "Sovereign Identity is locked or unreachable."
    log_guide "$OP_BIN signin"
    HAS_ERROR=1
  fi
fi

echo "--- 3. SSH Agent & Cryptographic Trust ---"
if ssh-add -l > /dev/null 2>&1; then
  log_ok "SSH Agent is responsive and active."
else
  if [[ "$IS_CI" == "true" ]]; then
    log_warn "SSH Agent unresponsive (expected in CI environment)."
  else
    log_warn "SSH Agent unresponsive. Attempting bridge recovery..."
    {{ if .is_wsl }}
    if command -v systemctl >/dev/null 2>&1; then
      systemctl --user restart 1password-bridge.service || true
    fi
    {{ end }}
    sleep 1
    if ssh-add -l > /dev/null 2>&1; then
      log_ok "Authentication bridge recovered successfully."
    else
      log_err "Authentication bridge failed to initialize."
      log_guide "Verify the 'SSH Agent' setting in 1Password Desktop App."
      HAS_ERROR=1
    fi
  fi
fi

exit "$HAS_ERROR"
