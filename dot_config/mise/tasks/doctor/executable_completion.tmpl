#!/usr/bin/env bash
# [MISE] description="Verify staged completion generation for HubSpot CLI"
{{/* [Reference]: https://mise.jdx.dev/tasks/file-tasks.html */}}{{ "" -}}

set -euo pipefail

GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

log_ok() { printf "  ${GREEN}✅ %s${NC}\n" "$1"; }
log_warn() { printf "  ${YELLOW}⚠️  %s${NC}\n" "$1"; }
log_err() { printf "  ${RED}❌ %s${NC}\n" "$1"; }
log_guide() { printf "  ${BLUE}👉 %s${NC}\n" "$1"; }

MISE_BIN="{{ .paths.mise }}"
COMP_DIR="{{ .paths.xdg_cache }}/zsh/completions"
HAS_ERROR=0
TMP_DIR="$(mktemp -d)"
TMP_FILE="$TMP_DIR/_hs"

cleanup() {
  rm -rf "$TMP_DIR"
}
trap cleanup EXIT

echo "--- 9. Completion Capability Verification ---"
if [[ -d "$COMP_DIR" ]]; then
  log_ok "Completion cache directory exists at $COMP_DIR."
else
  log_warn "Completion cache directory is missing at $COMP_DIR. Static asset checks will be skipped."
fi

if [[ -f "$COMP_DIR/_hs" ]]; then
  log_ok "Static HubSpot completion asset is present in cache."
else
  log_warn "Static HubSpot completion asset is not present in cache. This probe only verifies generated output and Zsh loadability."
fi

if ! "$MISE_BIN" exec npm:@hubspot/cli -- hs --help > /dev/null 2>&1; then
  log_err "HubSpot CLI is unavailable, so completion probing could not run."
  log_guide "Resolve 'doctor:hubspot' findings first, then rerun 'mise run doctor:completion'."
  HAS_ERROR=1
else
  if "$MISE_BIN" exec npm:@hubspot/cli -- hs completion zsh > "$TMP_FILE" 2>/dev/null && [[ -s "$TMP_FILE" ]]; then
    log_ok "HubSpot CLI generated non-empty Zsh completion output via 'hs completion zsh'."
  elif "$MISE_BIN" exec npm:@hubspot/cli -- hs completion > "$TMP_FILE" 2>/dev/null && [[ -s "$TMP_FILE" ]]; then
    log_ok "HubSpot CLI generated non-empty completion output via 'hs completion'."
  else
    log_err "HubSpot CLI did not generate completion output."
    log_guide "Inspect the installed package behavior with 'mise exec npm:@hubspot/cli -- hs completion'."
    HAS_ERROR=1
  fi

  if [[ -s "$TMP_FILE" ]]; then
    if zsh -fc '
      set -euo pipefail
      fpath=("$1" $fpath)
      autoload -Uz compinit
      compinit -D
      autoload -Uz _hs
      _hs >/dev/null 2>&1 || true
      typeset -f _hs >/dev/null
    ' zsh "$TMP_DIR"; then
      log_ok "Generated HubSpot completion passed a Zsh loadability probe."
    else
      log_err "Generated HubSpot completion failed the Zsh loadability probe."
      log_guide "Validate the emitted completion script syntax before re-enabling cached '_hs' assets."
      HAS_ERROR=1
    fi
  fi
fi

exit "$HAS_ERROR"
