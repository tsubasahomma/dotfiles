#!/usr/bin/env bash
# [MISE] description="Atomic Neovim plugin update and PR generation"
{{/* [Reference]: https://mise.jdx.dev/tasks/file-tasks.html */}}{{ "" -}}

set -euo pipefail

CHEZMOI_DIR="{{ .chezmoi.sourceDir }}"
LOCK_FILE="{{ .paths.xdg_config }}/nvim/lazy-lock.json"
BRANCH_NAME="chore/deps-nvim-$(date +%Y%m%d%H%M)"

cd "$CHEZMOI_DIR"

# --- 1. Pre-flight Checks (Zero-Speculation Gate) ---
if [[ -n "$(git status --porcelain=v1)" ]]; then
  echo "❌ [Pre-flight] Working directory is not clean. Aborting to prevent mixed state." >&2
  git status --short >&2
  exit 1
fi

if ! command -v gh >/dev/null 2>&1; then
  echo "❌ [Pre-flight] GitHub CLI (gh) is not installed." >&2
  exit 1
fi

if ! gh auth status >/dev/null 2>&1; then
  echo "❌ [Pre-flight] GitHub CLI is not authenticated." >&2
  exit 1
fi

# Query the remote first so a stale local origin/HEAD cannot select the wrong base.
default_branch="$(git remote show origin 2>/dev/null | awk -F': ' '/HEAD branch/ {print $2}' || true)"
if [[ -z "$default_branch" || "$default_branch" == "(unknown)" ]]; then
  default_branch="$(git symbolic-ref --quiet --short refs/remotes/origin/HEAD 2>/dev/null || true)"
  default_branch="${default_branch#origin/}"
fi

if [[ -z "$default_branch" || "$default_branch" == "(unknown)" ]]; then
  echo "❌ [Pre-flight] Could not determine origin default branch." >&2
  exit 1
fi

# --- 2. Isolation & Mutation ---
git fetch origin "+refs/heads/${default_branch}:refs/remotes/origin/${default_branch}"

if ! git rev-parse --verify --quiet "refs/remotes/origin/${default_branch}^{commit}" >/dev/null; then
  echo "❌ [Pre-flight] Fetched origin default branch is not available: $default_branch" >&2
  exit 1
fi

git switch --no-track -c "$BRANCH_NAME" "refs/remotes/origin/$default_branch"

echo "📦 [Neovim] Headless plugin update initiated..."
"{{ .paths.mise }}" exec aqua:neovim/neovim -- nvim --headless "+Lazy! update" +qa

# --- 3. State Promotion ---
chezmoi add "$LOCK_FILE"

# Diff against the specific managed file in the source state.
if git diff --quiet -- "$CHEZMOI_DIR/dot_config/nvim/lazy-lock.json"; then
  echo "✅ [State] No plugin updates found. lazy-lock.json is up to date."
  git checkout -
  git branch -D "$BRANCH_NAME"
  exit 0
fi

# --- 4. Atomic Commit & PR Generation ---
echo "🚀 [State] Updates detected. Committing and generating Pull Request..."
git add "$CHEZMOI_DIR/dot_config/nvim/lazy-lock.json"

artifact_dir="$(mktemp -d)"
cleanup_artifacts() {
  rm -rf "$artifact_dir"
}
trap cleanup_artifacts EXIT

commit_message_file="$artifact_dir/commit_message.txt"
pr_body_file="$artifact_dir/pr_body.md"
label_name="dependencies"
pr_label_args=()

cat > "$commit_message_file" <<'EOF_COMMIT_MESSAGE'
chore(deps): update neovim plugin lockfile

Update lazy-lock.json through the update:lazy-lock task.
EOF_COMMIT_MESSAGE

cat > "$pr_body_file" <<'EOF_PR_BODY'
## Summary

Update the Neovim plugin lock state generated by `update:lazy-lock`.

## Scope

This PR is limited to the managed Neovim `lazy-lock.json` source-state file.

## Changes

- Create the update branch from the fetched origin default branch.
- Promote the updated Neovim Lazy lockfile into chezmoi source state.
- Preserve existing Neovim plugin update semantics.
- Avoid manual lockfile edits.

## Validation

| Check | State | Evidence | Notes |
| --- | --- | --- | --- |
| `update:lazy-lock` | Passed | This PR was generated after the task completed the clean working-tree preflight, origin default-branch fetch, branch isolation, headless Lazy update, `chezmoi add`, commit, and push steps. | The task uses `set -euo pipefail`; command failures stop PR creation. |
| Update branch base | Passed | The task creates the update branch from the fetched origin default branch instead of the caller's current branch. | Prevents unrelated current-branch commits from entering this dependency update PR. |
| `lazy-lock.json` source-state diff | Passed | The task skipped PR creation unless `dot_config/nvim/lazy-lock.json` had a source-state diff. | Confirms this PR is only emitted when the lockfile changed. |
| Local manual validation | Pending | Not run by this automation. | Reviewers should run repository validation appropriate for dependency updates. |

## Risk

Updated plugins can introduce Neovim behavior or compatibility changes even when
configuration is unchanged.

## Rollback

Revert this PR to restore the previous `lazy-lock.json` state.

## Review notes

Review the lockfile diff before merging.

GitHub Checks and status checks are the source of truth for remote CI after PR
creation. Do not mirror dynamic CI status in this PR body.

To preserve SSH signature integrity, merge locally with fast-forward only after
required checks pass:

````zsh
EOF_PR_BODY
printf 'default_branch=%q\n' "$default_branch" >> "$pr_body_file"
printf 'branch_name=%q\n' "$BRANCH_NAME" >> "$pr_body_file"
cat >> "$pr_body_file" <<'EOF_PR_BODY'
git fetch origin "$default_branch"
if git show-ref --verify --quiet "refs/heads/$default_branch"; then
  git switch "$default_branch"
else
  git switch --track -c "$default_branch" "origin/$default_branch"
fi
git pull --ff-only origin "$default_branch"
git merge --ff-only "$branch_name"
git push origin "$default_branch"
git branch -d "$branch_name"
git push origin --delete "$branch_name"
````

## Out of scope

- Neovim plugin configuration changes.
- Manual `lazy-lock.json` edits.
- GitHub Actions workflow changes.
- Repository deliverable contract changes.

## Linked issues

Not linked to a tracked issue.
EOF_PR_BODY

# GPG/SSH signing is applied here through the user's Git configuration.
git commit -F "$commit_message_file"

git push -u origin "$BRANCH_NAME"

if gh label list --limit 1000 --json name --jq '.[].name' | grep -Fx -- "$label_name" >/dev/null; then
  pr_label_args=(--label "$label_name")
else
  echo "⚠️  [GitHub] Label '$label_name' not found. Creating PR without a label." >&2
fi

gh pr create \
  --base "$default_branch" \
  --head "$BRANCH_NAME" \
  --title "chore(deps): update neovim plugin lockfile" \
  --assignee "@me" \
  "${pr_label_args[@]}" \
  --body-file "$pr_body_file"

echo "✅ [Workflow] Pull Request created. Use GitHub Checks or status checks for remote CI status."
