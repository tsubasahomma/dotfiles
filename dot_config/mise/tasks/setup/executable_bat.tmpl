#!/usr/bin/env bash
# [MISE] description="Rebuild bat syntax cache for Catppuccin Mocha"
{{/* [Reference]: https://github.com/sharkdp/bat#customization */}}{{ "" -}}

set -euo pipefail

MISE_BIN="{{ .paths.mise }}"

echo "📦 [bat] Rebuilding theme cache..."
"$MISE_BIN" exec bat -- bat cache --build

echo "✅ [bat] Theme cache converged."
