#!/usr/bin/env bash
# [MISE] description="Atomic Neovim plugin and Mason package synchronization"
{{/* [Reference]: https://github.com/folke/lazy.nvim#-automation */}}{{ "" -}}

set -euo pipefail

MISE_BIN="{{ .paths.mise }}"
IS_CI="{{ env "CI" | default "false" }}"

if [[ "$IS_CI" == "true" ]]; then
  echo "📦 [Neovim] Restoring plugins from lockfile (CI Environment)..."
  "$MISE_BIN" exec neovim -- nvim --headless "+Lazy! restore" +qa
else
  echo "📦 [Neovim] Synchronizing plugins and Mason packages..."
  "$MISE_BIN" exec neovim -- nvim --headless "+Lazy! sync" +qa
fi

echo "✅ [Neovim] Environment converged."
