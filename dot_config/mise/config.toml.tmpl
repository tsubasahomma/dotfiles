{{- /* [Reference]: https://mise.jdx.dev/configuration.html */ -}}
# [Architecture]: Single Source of Truth (SSOT) for Toolchains.
# [Rationale]: All tools are dynamically expanded from FQIs in tools.yaml.

[env]
MISE_SIGSTORE = "false"
MISE_VERIFY_METADATA = "false"
MISE_PYTHON_GITHUB_ATTESTATIONS = "false"
PNPM_HOME = "{{ .paths.xdg_data }}/pnpm"

[tools]
{{- range $tool, $version := .mise_tools }}
"{{ $tool }}" = "{{ $version }}"
{{- end }}

[settings]
not_found_auto_install = true
yes = true
experimental = true
asdf_compat = false

[settings.github]
credential_command = "{{ .paths.op }} read 'op://Development/mise-cli-token/credential'"

[tasks.setup]
description = "Provision all ecosystem dependencies"
depends = ["setup:security", "setup:nvim-provider", "setup:pnpm", "setup:bat", "setup:vale"]
