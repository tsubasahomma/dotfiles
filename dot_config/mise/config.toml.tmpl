# [Rationale]: SSOT for developer tools. Eliminates imperative installation commands.
# Centralized all core CLI tooling to decouple from OS-level package managers.
[tools]
node = "lts"
rust = "latest"
# [Rationale]: Explicitly use 'aqua' backend to bypass 'vfox' API rate limiting (403) in CI.
"aqua:neovim/neovim" = "latest"
python = "3.13"
go = "latest"
uv = "latest"

# Git Infrastructure & TUI
tree-sitter = "latest"
lazygit = "latest"
gh = "latest"
"go:github.com/jesseduffield/lazydocker" = "latest"
pre-commit = "latest"

# Modern CLI Tools
zoxide = "latest"
eza = "latest"
bat = "latest"
ripgrep = "latest"
fd = "latest"
starship = "latest"
fzf = "latest"
"cargo:git-delta" = "latest"
"cargo:git-absorb" = "latest"

# Formatting Engines
shfmt = "latest"
stylua = "latest"
"npm:prettier" = "latest"

# Neovim Language Providers
"npm:neovim" = "latest"
"npm:@mermaid-js/mermaid-cli" = "latest"
"npm:repomix" = "latest"

# API & Data Processing
"go:github.com/noahgorstein/jqp" = "latest"
"go:github.com/mikefarah/yq/v4" = "latest"
"go:github.com/rs/curlie" = "latest"

[settings]
auto_install = true
experimental = true
asdf_compat = false

[tasks.doctor]
description = "System Health Check & Self-Healing Engine (Phase 4)"
run = "doctor"
