# [Rationale]: SSOT for developer tools. Eliminates imperative installation commands.
# Centralized all core CLI tooling to decouple from OS-level package managers.
[tools]
node = "lts"
rust = "latest"
neovim = "latest"
python = "3.13"
go = "latest"

# Git Infrastructure & TUI
tree-sitter = "latest"
lazygit = "latest"
gh = "latest"
"go:github.com/jesseduffield/lazydocker" = "latest"
pre-commit = "latest"

# Modern CLI Tools
zoxide = "latest"
eza = "latest"
bat = "latest"
ripgrep = "latest"
fd = "latest"
starship = "latest"
fzf = "latest"
"cargo:git-delta" = "latest"
"cargo:git-absorb" = "latest"

# [Rationale]: Formatting Engines (2026 Best Practice).
# Necessary for "Format on Save" functionality in Neovim/VSCode.
shfmt = "latest"
stylua = "latest"

# [Rationale]: Industry standard formatter for Markdown, JSON, and YAML.
"npm:prettier" = "latest"

# Neovim Language Providers & GTM Ops Tools
"npm:neovim" = "latest"
"npm:@mermaid-js/mermaid-cli" = "latest"
"npm:repomix" = "latest"

# API & Data Processing
"go:github.com/noahgorstein/jqp" = "latest"
"go:github.com/mikefarah/yq/v4" = "latest"
"go:github.com/rs/curlie" = "latest"
# jq is bootstrapped directly to ~/.local/bin/jq via Phase 0 to prevent cyclic dependencies.

[settings]
auto_install = true
experimental = true
asdf_compat = false

[tasks.doctor]
description = "System Health Check & Self-Healing Engine (Phase 4)"
run = "doctor"
