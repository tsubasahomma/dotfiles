{{- /* [Reference]: https://mise.jdx.dev/configuration.html */ -}}
# Dynamic mise configuration rendered from chezmoi host/user data.
# Static tool versions live in dot_config/mise/conf.d/10-tools.toml.

[env]
# Skip Python GitHub attestation verification to reduce mise install latency and noise.
# [Reference]: https://mise.jdx.dev/lang/python.html
MISE_PYTHON_GITHUB_ATTESTATIONS = "false"
PNPM_HOME = "{{ .paths.xdg_data }}/pnpm"


[settings]
not_found_auto_install = true
yes = true
experimental = true
asdf_compat = false

[settings.github]
credential_command = "{{ .paths.op }} read 'op://Development/mise-cli-token/credential'"
