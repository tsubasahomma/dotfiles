{{- /* [Reference]: https://mise.jdx.dev/dev-tools/ */ -}}
# [Architecture]: Single Source of Truth (SSOT) for Toolchains.
# [Note]: Neovim is deterministically pinned to '0.12.1' to physically bypass
# non-deterministic API discovery and mitigate GitHub API Rate Limits (HTTP 403).
[tools]
node = "lts"
rust = "latest"
neovim = "0.12.1"
python = "3.13"
go = "latest"
uv = "latest"

# Development Infrastructure
tree-sitter = "latest"
lazygit = "latest"
gh = "latest"
"go:github.com/jesseduffield/lazydocker" = "latest"
pre-commit = "latest"
vale = "latest"

# Modern CLI Utilities
zoxide = "latest"
eza = "latest"
bat = "latest"
ripgrep = "latest"
fd = "latest"
starship = "latest"
fzf = "latest"
"cargo:git-delta" = "latest"
"cargo:git-absorb" = "latest"

# Formatting & Linting Engines
shfmt = "latest"
stylua = "latest"
"npm:prettier" = "latest"

# Neovim Ecosystem Providers
"npm:neovim" = "latest"
"npm:@mermaid-js/mermaid-cli" = "latest"
"npm:repomix" = "latest"

# Data Processing
"go:github.com/noahgorstein/jqp" = "latest"
"go:github.com/mikefarah/yq/v4" = "latest"
"go:github.com/rs/curlie" = "latest"

[settings]
auto_install = true
experimental = true
asdf_compat = false

[tasks.doctor]
description = "System Health Check & Self-Healing Engine"
run = "doctor"
