// [Architecture]: Deterministic Dependency Governance
// [Rationale]: Enforces immutable action digests via Renovate to prevent supply-chain attacks.
// [Reference]: https://docs.renovatebot.com/presets-helpers/#helperspingithubactiondigests
{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests",
    ":dependencyDashboard"
  ],
  "labels": ["dependencies", "renovate"],
  "commitMessageAction": "Update",
  "commitMessageTopic": "{{depName}}",
  "commitMessageExtra": "to v{{newVersion}}",
  "packageRules": [
    {
      "matchManagers": ["custom.regex"],
      "groupName": "Infrastructure Core & Runtime Ecosystem"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Parse .chezmoidata/tools.yaml for versions with renovate comments",
      "managerFilePatterns": ["/^\\.chezmoidata/tools\\.yaml$/"],
      "matchStrings": [
        "\"?(?<depName>[a-zA-Z0-9\\-_:/@\\.]+)\"?:\\s*\"(?<currentValue>[a-zA-Z0-9\\-\\.]+)\"\\s*#\\s*renovate:\\s*datasource=(?<datasource>[a-zA-Z0-9-]+)(?:\\s+packageName=(?<packageName>[^\\s#]+))?"
      ]
    }
  ]
}
